<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cardiolink.Controllers.RegisterController"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #f8f8fb;">

    <!-- GAUCHE : Formulaire -->
    <ScrollPane fitToWidth="true" prefWidth="500"
                style="-fx-background-color: white; -fx-background: white;
                       -fx-border-color: transparent;">
        <VBox alignment="TOP_LEFT"
              style="-fx-background-color: white; -fx-padding: 40 40 40 40;"
              spacing="4">

            <Label text="Create Account"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

            <Label text="Join CardioLink and take control of your cardiac health today."
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-padding: 4 0 16 0;"/>

            <!-- Email -->
            <Label text="Email Address"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <TextField fx:id="emailField" promptText="votre@email.com"
                       prefHeight="42" prefWidth="400"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Password -->
            <Label text="Password"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"
                           prefHeight="42" prefWidth="400"
                           style="-fx-background-color: white;
                                  -fx-border-color: #dedede; -fx-border-width: 1.5;
                                  -fx-border-radius: 10; -fx-background-radius: 10;
                                  -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Last Name -->
            <Label text="Last Name"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <TextField fx:id="nomField" promptText="Votre nom"
                       prefHeight="42" prefWidth="400"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- First Name -->
            <Label text="First Name"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <TextField fx:id="prenomField" promptText="Votre prénom"
                       prefHeight="42" prefWidth="400"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Phone Number -->
            <Label text="Phone Number"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <TextField fx:id="phoneField" promptText="+216 XX XXX XXX"
                       prefHeight="42" prefWidth="400"
                       style="-fx-background-color: white;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Role -->
            <Label text="Role"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <ComboBox fx:id="roleCombo"
                      prefHeight="42" prefWidth="400"
                      style="-fx-background-color: white;
                             -fx-border-color: #dedede; -fx-border-width: 1.5;
                             -fx-border-radius: 10; -fx-background-radius: 10;
                             -fx-font-size: 13px;"/>

            <!-- Known Allergies -->
            <Label text="Known Allergies"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <TextArea fx:id="allergiesField"
                      promptText="List any known allergies (optional)"
                      prefHeight="80" prefWidth="400"
                      style="-fx-background-color: white;
                             -fx-border-color: #dedede; -fx-border-width: 1.5;
                             -fx-border-radius: 10; -fx-background-radius: 10;
                             -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Adresse cabinet -->
            <Label text="Adresse du cabinet (optionnel - pour les médecins)"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 8 0 0 0;"/>
            <TextField fx:id="adresseField" promptText="Adresse du cabinet"
                       prefHeight="42" prefWidth="400"
                       style="-fx-background-color: white;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 10; -fx-background-radius: 10;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <!-- Terms -->
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-padding: 10 0 0 0;">
                <CheckBox fx:id="termsCheck"/>
                <Label text="I agree to the Terms and Conditions"
                       style="-fx-font-size: 13px; -fx-text-fill: #1a1a2e;"/>
            </HBox>

            <!-- Message erreur -->
            <Label fx:id="errorLabel" text=""
                   wrapText="true"
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 12px;"/>

            <!-- Message succès -->
            <Label fx:id="successLabel" text=""
                   wrapText="true"
                   style="-fx-text-fill: #3B6D11; -fx-font-size: 12px;"/>

            <!-- Bouton Register -->
            <Button text="Register Now"
                    onAction="#handleRegister"
                    prefWidth="400" prefHeight="44"
                    style="-fx-background-color: linear-gradient(to right, #D4537E, #7F77DD);
                           -fx-text-fill: white; -fx-font-size: 15px;
                           -fx-font-weight: bold; -fx-background-radius: 10;
                           -fx-cursor: hand;">
                <VBox.margin><Insets top="8"/></VBox.margin>
            </Button>

            <!-- Lien login -->
            <HBox alignment="CENTER" spacing="4">
                <VBox.margin><Insets top="12"/></VBox.margin>
                <Label text="Already have an account?"
                       style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                <Label fx:id="loginLink" text="Sign in here"
                       onMouseClicked="#goToLogin"
                       style="-fx-font-size: 13px; -fx-text-fill: #7F77DD;
                              -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- DROITE : Visuel décoratif -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: linear-gradient(to bottom right, #fce4ec, #ede7f6);">
        <StackPane prefWidth="260" prefHeight="260"
                   style="-fx-background-color: rgba(180,160,220,0.25);
                          -fx-background-radius: 130;">
            <Label text="💊" style="-fx-font-size: 64px;"/>
        </StackPane>
    </StackPane>

</HBox>