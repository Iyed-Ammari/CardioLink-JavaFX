<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" 
            stylesheets="@css/rdv_style.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cardiolink.Controllers.AfficherRDVMedecin">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" styleClass="navbar">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="navbar-brand-heart" text="❤" />
                <Label styleClass="navbar-brand-text" text="CardioLink" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goHome" styleClass="nav-button" text="🏠 Home" />
            <Button onAction="#goCommunity" styleClass="nav-button" text="👥 Community" />
            <Button onAction="#goSuivis" styleClass="nav-button" text="📊 Mes Suivis" />
            <Button onAction="#goRDV" styleClass="nav-button, nav-button-active" text="📅 Mes RDV" />
            <Button onAction="#goDossier" styleClass="nav-button" text="🗂 Mon Dossier" />
            <Button onAction="#goProfil" styleClass="nav-button" text="👤 Mon Profil" />
            <Button onAction="#handleLogout" styleClass="nav-button, nav-logout" text="🚪 Logout" />
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18" styleClass="avatar-circle" />
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="?" />
            </StackPane>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="25.0" styleClass="content-area">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                            <VBox HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="subtitle-text" text="Espace Praticien" />
                                    <Label styleClass="title-text" text="Mes Consultations" />
                                </children>
                            </VBox>
                            <HBox spacing="10.0">
                               <children>
                                   <Button mnemonicParsing="false" onAction="#showPrediction" styleClass="action-button" text="📈 Voir Prédiction" />
                                   <Button mnemonicParsing="false" onAction="#syncWithGoogleCalendar" styleClass="google-btn" text="📅 Google Calendar" />
                               </children>
                            </HBox>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card">
                        <children>
                            <VBox spacing="8.0">
                                <Label styleClass="label-text" text="Recherche rapide" />
                                <TextField fx:id="searchField" prefWidth="250.0" promptText="Patient, type, motif..." />
                            </VBox>

                            <VBox spacing="8.0">
                                <Label styleClass="label-text" text="Filtrer par Statut" />
                                <ComboBox fx:id="filterStatut" prefWidth="180.0" promptText="Tous les statuts" />
                            </VBox>

                            <HBox alignment="BOTTOM_CENTER" spacing="12.0">
                                <children>
                                    <Button mnemonicParsing="false" onAction="#handleSortDate" styleClass="action-button" text="📅 Trier" />
                                    <Button mnemonicParsing="false" onAction="#resetFilters" styleClass="action-button" text="Réinitialiser" />
                                </children>
                            </HBox>
                        </children>
                    </HBox>

                    <TableView fx:id="tableRDV" prefHeight="400.0" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDate" prefWidth="150.0" text="Date &amp; Heure" />
                            <TableColumn fx:id="colPatient" prefWidth="180.0" text="Patient" />
                            <TableColumn fx:id="colType" prefWidth="150.0" text="Type" />
                            <TableColumn fx:id="colStatut" prefWidth="140.0" text="Statut" />
                            <TableColumn fx:id="colOrdonnance" prefWidth="180.0" text="Ordonnance" />
                            <TableColumn fx:id="colActions" prefWidth="180.0" text="Actions" />
                            <TableColumn fx:id="colLienVisio" prefWidth="180.0" text="Téléconsultation" />
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

