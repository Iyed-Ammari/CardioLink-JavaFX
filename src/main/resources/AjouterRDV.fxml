<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" 
            stylesheets="@css/rdv_style.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cardiolink.Controllers.AjouterRDV">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" styleClass="navbar">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="navbar-brand-heart" text="❤" />
                <Label styleClass="navbar-brand-text" text="CardioLink" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goHome" styleClass="nav-button" text="🏠 Home" />
            <Button onAction="#goCommunity" styleClass="nav-button" text="👥 Community" />
            <Button onAction="#goSuivis" styleClass="nav-button" text="📊 Mes Suivis" />
            <Button onAction="#goRDV" styleClass="nav-button" text="📅 Mes RDV" />
            <Button onAction="#goDossier" styleClass="nav-button" text="🗂 Mon Dossier" />
            <Button onAction="#goProfil" styleClass="nav-button" text="👤 Mon Profil" />
            <Button onAction="#handleLogout" styleClass="nav-button, nav-logout" text="🚪 Logout" />
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18" styleClass="avatar-circle" />
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="?" />
            </StackPane>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="30.0" styleClass="content-area">
                <children>
                    <VBox maxWidth="600.0" spacing="25.0" styleClass="card">
                        <children>
                            <Label fx:id="titleLabel" styleClass="title-text" text="Prendre un Rendez-vous" />
                            
                            <VBox spacing="8.0">
                                <Label styleClass="label-text" text="Médecin" />
                                <ComboBox fx:id="medecin" maxWidth="Infinity" promptText="Choisir un médecin" />
                            </VBox>

                            <HBox spacing="20.0">
                                <children>
                                    <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                                        <Label styleClass="label-text" text="Date" />
                                        <DatePicker fx:id="date" maxWidth="Infinity" />
                                    </VBox>
                                    <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                                        <Label styleClass="label-text" text="Heure" />
                                        <ComboBox fx:id="heure" maxWidth="Infinity" promptText="Choisir l'heure" />
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="8.0">
                                <Label styleClass="label-text" text="Type de consultation" />
                                <ComboBox fx:id="type" maxWidth="Infinity" promptText="Choisir le type" />
                            </VBox>

                            <VBox spacing="8.0">
                                <Label styleClass="label-text" text="Motif / Remarques" />
                                <TextArea fx:id="remarques" prefHeight="100.0" promptText="Précisez le motif de votre visite..." wrapText="true" />
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                <children>
                                    <Button onAction="#handleCancel" styleClass="action-button" text="Annuler" />
                                    <Button fx:id="btnSave" onAction="#save" styleClass="gradient-button" text="Confirmer le rendez-vous" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>