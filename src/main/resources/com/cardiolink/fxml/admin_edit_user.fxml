<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.controllers.AdminEditUserController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-color: #f8f8ff;">
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_LEFT" spacing="18" style="-fx-padding: 40 200;">

                <Label text="✏ Modifier le rôle de l'utilisateur"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;
                              -fx-text-fill: #1a1a2e;"/>

                <Hyperlink text="← Retour liste" onAction="#goBack"
                           style="-fx-text-fill: #7F77DD; -fx-font-size: 13px;
                                  -fx-padding: 0;"/>

                <!-- Info utilisateur (lecture seule) -->
                <VBox spacing="6">
                    <Label text="Utilisateur"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #333;"/>
                    <Label fx:id="userInfoLabel" text=""
                           style="-fx-font-size: 14px; -fx-text-fill: #7F77DD;
                                  -fx-background-color: #f0f0fb;
                                  -fx-padding: 10 14; -fx-background-radius: 8;"/>
                </VBox>

                <!-- Rôle -->
                <VBox spacing="6">
                    <Label text="Rôle"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #333;"/>
                    <ComboBox fx:id="roleCombo" maxWidth="400"
                              style="-fx-background-color: white;
                                     -fx-border-color: #7F77DD;
                                     -fx-border-width: 1.5;
                                     -fx-border-radius: 8; -fx-font-size: 14px;"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       style="-fx-text-fill: #E24B4A; -fx-font-size: 13px;"/>
                <Label fx:id="successLabel" text=""
                       style="-fx-text-fill: #27ae60; -fx-font-size: 13px;"/>

                <Button text="💾 Enregistrer le rôle"
                        onAction="#handleSave"
                        style="-fx-background-color: linear-gradient(to right, #E24B4A, #7F77DD);
                               -fx-text-fill: white; -fx-font-size: 15px;
                               -fx-font-weight: bold; -fx-padding: 14 40;
                               -fx-background-radius: 25; -fx-cursor: hand;"/>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>