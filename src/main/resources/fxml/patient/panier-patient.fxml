<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.Controllers.PatientPanierController"
            prefWidth="1600.0" prefHeight="900.0"
            style="-fx-background-color: #F6F7FB;">

    <left>
        <VBox spacing="18"
              prefWidth="340"
              style="-fx-background-color: white; -fx-padding: 28 20 20 20; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="56" prefHeight="56"
                           style="-fx-background-color: linear-gradient(to bottom right, #F82239, #2F60F5); -fx-background-radius: 18;">
                    <Label text="CL"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                </StackPane>

                <VBox spacing="4">
                    <Label text="CardioLink"
                           style="-fx-text-fill: #111827; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                    <Label text="Espace Patient"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <VBox spacing="12" style="-fx-padding: 24 0 0 0;">
                <Button text="Produits"
                        onAction="#goToProduits"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>

                <Button text="Mon panier"
                        onAction="#goToPanier"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>

                <Button text="Mes commandes"
                        onAction="#goToCommandes"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 16 0 0 0; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, rgba(248,34,57,0.22), rgba(47,96,245,0.22)); -fx-background-radius: 18;">
                    <Label text="P"
                           style="-fx-text-fill: #1F2937; -fx-font-size: 16px; -fx-font-weight: 900;"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="Patient"
                           style="-fx-text-fill: #111827; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                    <Label text="ROLE_USER"
                           style="-fx-text-fill: #2F60F5; -fx-font-size: 13px; -fx-font-weight: 800;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22"
              style="-fx-background-color: #F6F7FB; -fx-padding: 28;">

            <VBox spacing="8"
                  style="-fx-background-color: #0D0F14; -fx-background-radius: 18; -fx-padding: 18 24 18 24;">
                <Label text="Espace Patient"
                       style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12px; -fx-font-weight: 700;"/>
                <Label text="Mon panier"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                <Label text="Vérifiez vos produits avant de valider la commande"
                       style="-fx-text-fill: rgba(255,255,255,0.70); -fx-font-size: 12px; -fx-font-weight: 600;"/>
            </VBox>

            <HBox spacing="18" VBox.vgrow="ALWAYS">
                <VBox spacing="14"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 24; -fx-border-color: #E5E7EB; -fx-border-radius: 24; -fx-padding: 22;">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Produits du panier"
                               style="-fx-text-fill: #111827; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="countLabel"
                               text=""
                               style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                    </HBox>

                    <ScrollPane fx:id="cartScrollPane"
                                fitToWidth="true"
                                fitToHeight="true"
                                VBox.vgrow="ALWAYS"
                                hbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                        <content>
                            <TilePane fx:id="cartContainer"
                                      hgap="16"
                                      vgap="18"
                                      prefColumns="1"
                                      prefTileWidth="860"
                                      style="-fx-padding: 8;"/>
                        </content>
                    </ScrollPane>

                    <Label fx:id="messageLabel"
                           text=""
                           wrapText="true"
                           style="-fx-font-size: 14px; -fx-font-weight: 800;"/>
                </VBox>

                <VBox spacing="16"
                      prefWidth="330"
                      style="-fx-background-color: white; -fx-background-radius: 24; -fx-border-color: #E5E7EB; -fx-border-radius: 24; -fx-padding: 22;">
                    <Label text="Résumé"
                           style="-fx-text-fill: #111827; -fx-font-size: 22px; -fx-font-weight: 900;"/>

                    <VBox spacing="10">
                        <Label text="Nombre de lignes"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                        <Label fx:id="lineCountValue"
                               text="0"
                               style="-fx-text-fill: #111827; -fx-font-size: 20px; -fx-font-weight: 900;"/>

                        <Label text="Montant total"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                        <Label fx:id="totalValue"
                               text="0.00 DT"
                               style="-fx-text-fill: #F82239; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                    </VBox>

                    <Button text="Valider la commande"
                            onAction="#handleValiderCommande"
                            prefHeight="48"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-cursor: hand;"/>
                    <Button text="Payer maintenant"
                            onAction="#handlePayerCommande"
                            prefHeight="48"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-cursor: hand;"/>
                    <Button text="Vider le panier"
                            onAction="#handleViderPanier"
                            prefHeight="48"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: white; -fx-text-fill: #B42318; -fx-font-size: 15px; -fx-font-weight: 800; -fx-border-color: #FECACA; -fx-border-radius: 14; -fx-background-radius: 14; -fx-cursor: hand;"/>

                    <Button text="Continuer mes achats"
                            onAction="#goToProduits"
                            prefHeight="48"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 15px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-cursor: hand;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>