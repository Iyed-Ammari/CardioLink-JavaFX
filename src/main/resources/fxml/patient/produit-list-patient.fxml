<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.Controllers.PatientProduitListController"
            prefWidth="1600.0" prefHeight="900.0"
            style="-fx-background-color: #F6F7FB;">

    <left>
        <VBox spacing="18"
              prefWidth="340"
              style="-fx-background-color: white; -fx-padding: 28 20 20 20; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

            <HBox spacing="14" alignment="CENTER_LEFT">
                <StackPane prefWidth="56" prefHeight="56"
                           style="-fx-background-color: linear-gradient(to bottom right, #F82239, #2F60F5); -fx-background-radius: 18;">
                    <Label text="CL"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                </StackPane>
                <VBox spacing="4">
                    <Label text="CardioLink"
                           style="-fx-text-fill: #111827; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                    <Label text="Espace Patient"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <VBox spacing="12" style="-fx-padding: 24 0 0 0;">
                <Button fx:id="btnProduits"
                        text="Produits"
                        onAction="#goToProduits"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>

                <Button fx:id="btnPanier"
                        text="Mon panier"
                        onAction="#goToPanier"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>

                <Button fx:id="btnCommandes"
                        text="Mes commandes"
                        onAction="#goToCommandes"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>

                <Button fx:id="btnFavoris"
                        text="♡  Mes favoris"
                        onAction="#goToFavoris"
                        prefHeight="54"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800; -fx-background-radius: 18; -fx-cursor: hand;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Récemment consultés — sidebar -->
            <VBox fx:id="recentlyViewedSection"
                  spacing="8"
                  managed="false"
                  visible="false"
                  style="-fx-background-color: #F6F7FB; -fx-background-radius: 14; -fx-border-color: #E5E7EB; -fx-border-radius: 14; -fx-padding: 12 10;">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="👁" style="-fx-font-size: 12px;"/>
                    <Label text="Récemment consultés"
                           style="-fx-text-fill: #111827; -fx-font-size: 12px; -fx-font-weight: 900;"/>
                </HBox>
                <VBox fx:id="recentlyViewedContainer" spacing="6"/>
            </VBox>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 16 0 0 0; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <StackPane prefWidth="50" prefHeight="50"
                           style="-fx-background-color: linear-gradient(to bottom right, rgba(248,34,57,0.22), rgba(47,96,245,0.22)); -fx-background-radius: 18;">
                    <Label text="P"
                           style="-fx-text-fill: #1F2937; -fx-font-size: 16px; -fx-font-weight: 900;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Patient"
                           style="-fx-text-fill: #111827; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                    <Label text="ROLE_USER"
                           style="-fx-text-fill: #2F60F5; -fx-font-size: 13px; -fx-font-weight: 800;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22"
              style="-fx-background-color: #F6F7FB; -fx-padding: 28;">

            <VBox spacing="8"
                  style="-fx-background-color: #0D0F14; -fx-background-radius: 18; -fx-padding: 18 24 18 24;">
                <Label text="Catalogue Patient"
                       style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12px; -fx-font-weight: 700;"/>
                <Label text="Produits disponibles"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                <Label text="Choisissez les produits médicaux et ajoutez-les facilement à votre panier"
                       style="-fx-text-fill: rgba(255,255,255,0.70); -fx-font-size: 12px; -fx-font-weight: 600;"/>
            </VBox>

            <HBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 22; -fx-border-color: #E5E7EB; -fx-border-radius: 22; -fx-padding: 18;">
                <TextField fx:id="searchField"
                           promptText="Rechercher un produit..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #E5E7EB; -fx-padding: 14 16; -fx-font-size: 15px;"/>
                <Button text="Rechercher"
                        onAction="#handleSearch"
                        prefHeight="48"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800; -fx-background-radius: 14; -fx-padding: 10 22; -fx-cursor: hand;"/>
                <Button text="Réinitialiser"
                        onAction="#handleReset"
                        prefHeight="48"
                        style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-size: 15px; -fx-font-weight: 800; -fx-border-color: #E5E7EB; -fx-border-radius: 14; -fx-background-radius: 14; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="14"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 24; -fx-border-color: #E5E7EB; -fx-border-radius: 24; -fx-padding: 22;">

                <HBox alignment="CENTER_LEFT">
                    <Label text="Catalogue"
                           style="-fx-text-fill: #111827; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="countLabel"
                           text=""
                           style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                </HBox>

                <ScrollPane fx:id="productScrollPane"
                            fitToWidth="true"
                            fitToHeight="true"
                            VBox.vgrow="ALWAYS"
                            hbarPolicy="NEVER"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <TilePane fx:id="productContainer"
                                  hgap="22"
                                  vgap="22"
                                  prefColumns="2"
                                  prefTileWidth="360"
                                  style="-fx-padding: 8;"/>
                    </content>
                </ScrollPane>

                <Label fx:id="messageLabel"
                       text=""
                       wrapText="true"
                       style="-fx-font-size: 14px; -fx-font-weight: 800;"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
