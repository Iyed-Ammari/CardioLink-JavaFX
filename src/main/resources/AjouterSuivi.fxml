<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0"
            style="-fx-background-color: linear-gradient(to bottom, #11152f, #17193a);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.AjouterSuivi">

    <children>
        <VBox spacing="20.0"
              AnchorPane.topAnchor="30.0"
              AnchorPane.leftAnchor="40.0"
              AnchorPane.rightAnchor="40.0"
              AnchorPane.bottomAnchor="30.0">

            <children>

                <Label text="Mes Suivis Cardiaques" textFill="WHITE">
                    <font>
                        <Font size="30.0" />
                    </font>
                </Label>

                <HBox spacing="15">
                    <children>
                        <Button fx:id="btnNouveauSuivi"
                                text="Nouveau Suivi"
                                onAction="#ouvrirFenetreAjout"
                                prefWidth="180.0"
                                prefHeight="50.0"
                                style="-fx-background-color: linear-gradient(to right, #ff5f8f, #7b8dff);
                                       -fx-text-fill: white;
                                       -fx-font-size: 18px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />

                        <Button fx:id="btnConsulterSuivis"
                                text="Consulter les suivis"
                                onAction="#ouvrirConsulterSuivi"
                                prefWidth="210.0"
                                prefHeight="50.0"
                                style="-fx-background-color: linear-gradient(to right, #d9416c, #5b6fff);
                                       -fx-text-fill: white;
                                       -fx-font-size: 16px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />

                        <Button fx:id="btnInterventions"
                                text="Interventions"
                                onAction="#ouvrirInterventions"
                                prefWidth="180.0"
                                prefHeight="50.0"
                                style="-fx-background-color: linear-gradient(to right, #6a4df5, #4f7cff);
                                       -fx-text-fill: white;
                                       -fx-font-size: 16px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT"
                      prefHeight="50.0"
                      spacing="10.0"
                      style="-fx-background-color: #1e2555;
                             -fx-background-radius: 10;
                             -fx-border-color: #2f6fff;
                             -fx-border-radius: 10;
                             -fx-border-width: 0 0 0 4;">
                    <padding>
                        <Insets top="10" right="15" bottom="10" left="20"/>
                    </padding>
                    <children>
                        <Label fx:id="lblMessage"
                               text="Chargement..."
                               style="-fx-text-fill: #b9c6ff; -fx-font-size: 16px;" />
                    </children>
                </HBox>

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Liste des suivis"
                               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />

                        <ListView fx:id="listSuivis"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="380.0"
                                  style="-fx-control-inner-background: #1b2046;
                                         -fx-background-color: #1b2046;
                                         -fx-background-radius: 12;
                                         -fx-border-radius: 12;
                                         -fx-border-color: #2a3470;
                                         -fx-text-fill: white;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>