<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f4f6fb;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cardiolink.controllers.ForumController">

    <!-- ================= TOP ================= -->
    <top>
        <VBox spacing="10">

            <!-- STATS -->
            <VBox fx:id="statsBox"
                  spacing="15"
                  style="-fx-padding:15;"/>

            <!-- HEADER -->
            <HBox spacing="15"
                  style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:15;">

                <Label text="CardioLink"
                       style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#ff4d6d;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER">
                    <Label text="Wellness Community"
                           style="-fx-font-size:16; -fx-font-weight:bold;"/>
                    <Label text="Connect, Share, and Grow Together"
                           style="-fx-text-fill:gray; -fx-font-size:11;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="searchField"
                           prefWidth="220"
                           promptText="Rechercher par titre..."
                           style="-fx-background-radius:20;"/>

                <ComboBox fx:id="filterBox"
                          prefWidth="120"/>

            </HBox>

        </VBox>
    </top>

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox spacing="15"
              prefWidth="220"
              style="-fx-background-color:white; -fx-padding:20;">

            <Label text="CardioLink"
                   style="-fx-font-size:18; -fx-text-fill:#ff4d6d; -fx-font-weight:bold;"/>

            <Button text="Community"
                    style="-fx-background-color: linear-gradient(to right,#ff4d6d,#4d6dff);
                           -fx-text-fill:white;
                           -fx-background-radius:20;"/>

            <Button text="Home"/>
            <Button text="Mes Suivis"/>
            <Button text="Mon Dossier Médical"/>
            <Button text="Logout"/>

        </VBox>
    </left>

    <!-- ================= CENTER ================= -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background:#f4f6fb;">
            <VBox spacing="20" style="-fx-padding:20;">

                <!-- CREATE POST -->
                <VBox spacing="10"
                      style="-fx-background-color:white;
                             -fx-padding:15;
                             -fx-background-radius:15;
                             -fx-effect:dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,4);">

                    <Label text="Créer une publication"
                           style="-fx-font-weight:bold; -fx-font-size:14;"/>

                    <TextField fx:id="titleField"
                               promptText="Ajouter un titre (optionnel)"
                               style="-fx-background-radius:10;"/>

                    <TextField fx:id="contentField"
                               promptText="Parler..."
                               style="-fx-background-radius:10;"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Publier"
                                onAction="#addPost"
                                style="-fx-background-color:#2f6bff;
                                       -fx-text-fill:white;
                                       -fx-background-radius:10;
                                       -fx-padding:8 20;"/>
                    </HBox>

                </VBox>

                <!-- POSTS -->
                <VBox fx:id="postContainer"
                      spacing="20"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>