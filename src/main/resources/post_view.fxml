<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<!-- ========================================================= -->
<!-- ROOT LAYOUT : APPLICATION PRINCIPALE (BorderPane)        -->
<!-- ========================================================= -->
<BorderPane style="-fx-background-color: #f4f6fb;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cardiolink.Controllers.ForumController">

    <!-- ========================================================= -->
    <!-- HEADER / TOP BAR : LOGO + TITRE + RECHERCHE              -->
    <!-- ========================================================= -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="20" left="20" bottom="10"/>
            </padding>

            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">

                <!-- Logo / Nom application -->
                <Label text="CardioLink"
                       style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#ff4d6d;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Titre central -->
                <VBox alignment="CENTER">
                    <Label text="Wellness Community"
                           style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill: #1f2937;"/>
                    <Label text="Connect, Share, and Grow Together"
                           style="-fx-text-fill:gray; -fx-font-size:11;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Recherche + filtre -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField"
                               prefWidth="220"
                               promptText="Rechercher par titre..."
                               style="-fx-background-radius:20; -fx-background-color: #f1f5f9;"/>
                    <ComboBox fx:id="filterBox" prefWidth="120" style="-fx-background-radius: 20;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- ========================================================= -->
    <!-- LEFT SIDEBAR : NAVIGATION MENU                           -->
    <!-- ========================================================= -->
    <left>
        <VBox spacing="15" prefWidth="220"
              style="-fx-background-color:white; -fx-padding:20; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 0 0;">

            <Label text="Menu" style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-font-size: 12;"/>

            <!-- Section communauté -->
            <Button text="Community" maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: linear-gradient(to right,#ff4d6d,#4d6dff);
                           -fx-text-fill:white; -fx-background-radius:10; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10;"/>

            <!-- Navigation -->
            <Button fx:id="homeButton" onAction="#goHome" text="Home" maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 10;"/>

            <Button text="Mes Suivis" maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 10;"/>

            <Button fx:id="dossierButton" onAction="#goDossier" text="Mon Dossier Médical"
                    maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 10;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>

            <!-- Logout -->
            <Button text="Logout" maxWidth="Infinity" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10;"/>
        </VBox>
    </left>

    <!-- ========================================================= -->
    <!-- RIGHT SIDEBAR : STATS + INFO SANTÉ                       -->
    <!-- ========================================================= -->
    <right>
        <VBox spacing="20" prefWidth="250" style="-fx-padding: 20;">

            <!-- Tableau de bord -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <Label text="Tableau de bord" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #1f2937;"/>
                <Separator/>
                <VBox fx:id="statsBox" spacing="10"/>
            </VBox>

            <!-- Bloc information santé -->
            <VBox spacing="10" style="-fx-background-color: #2f6bff; -fx-padding: 15; -fx-background-radius: 15;">
                <Label text="Santé Cardiaque" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label text="Partagez vos progrès avec la communauté !" style="-fx-text-fill: white; -fx-font-size: 11;" wrapText="true"/>
            </VBox>
        </VBox>
    </right>

    <!-- ========================================================= -->
    <!-- CENTER : POSTS + CREATION + EDIT FORMS                   -->
    <!-- ========================================================= -->
    <center>
        <StackPane>

            <!-- SCROLL PRINCIPAL (Feed posts) -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background:#f4f6fb; -fx-background-color: transparent; -fx-hbar-policy: NEVER;">

                <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding:20;">

                    <!-- FORMULAIRE : NOUVELLE PUBLICATION -->
                    <VBox spacing="12" maxWidth="540"
                          style="-fx-background-color:white; -fx-padding:20; -fx-background-radius:15;
             -fx-effect:dropshadow(three-pass-box, rgba(0,0,0,0.08), 10,0,0,4);">

                        <Label text="Nouvelle publication"
                               style="-fx-font-weight:bold; -fx-font-size:15; -fx-text-fill: #1f2937;"/>

                        <TextField fx:id="titleField"
                                   promptText="Titre de votre sujet..."
                                   style="-fx-background-radius:10; -fx-padding: 12; -fx-background-color: #f8fafc; -fx-border-color: #e5e7eb; -fx-border-radius: 10;"/>

                        <TextArea fx:id="contentField"
                                  promptText="Quoi de neuf aujourd'hui ?"
                                  prefHeight="100" wrapText="true"
                                  style="-fx-background-radius:10; -fx-background-color: #f8fafc; -fx-border-color: #e5e7eb; -fx-border-radius: 10;"/>

                        <!-- ================= IMAGE SECTION ================= -->
                        <HBox spacing="10" alignment="CENTER_LEFT">

                            <Button text="📷 Ajouter image"
                                    onAction="#chooseImage"
                                    style="-fx-background-color:#e5e7eb; -fx-text-fill:#1f2937; -fx-background-radius:8; -fx-cursor: hand;"/>

                            <Label fx:id="imageLabel"
                                   text="Aucune image sélectionnée"
                                   style="-fx-text-fill:gray; -fx-font-size:11;"/>

                        </HBox>

                        <!-- ================= SUBMIT ================= -->
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Publier"
                                    onAction="#addPost"
                                    style="-fx-background-color:#2f6bff; -fx-text-fill:white; -fx-background-radius:10; -fx-padding:10 30; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        </HBox>

                    </VBox>

                    <!-- CONTAINER POSTS DYNAMIQUES -->
                    <VBox fx:id="postContainer"
                          spacing="25"
                          alignment="TOP_CENTER"
                          maxWidth="540"/>

                </VBox>

            </ScrollPane>

            <!-- ===================================================== -->
            <!-- EDIT COMMENTAIRE                                     -->
            <!-- ===================================================== -->
            <VBox fx:id="editCommentBox" visible="false" managed="false" spacing="15"
                  maxWidth="400" maxHeight="250"
                  style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 20;
                         -fx-border-color: #4d6dff; -fx-border-width: 2;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 60, 0, 0, 0);">

                <Label text="Modifier le commentaire"/>

                <TextArea fx:id="editCommentField" prefHeight="100" wrapText="true"/>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Annuler" onAction="#cancelEditComment"/>
                    <Button text="Enregistrer" onAction="#updateComment"/>
                </HBox>
            </VBox>

            <!-- ===================================================== -->
            <!-- EDIT POST                                            -->
            <!-- ===================================================== -->
            <VBox fx:id="editBox" visible="false" managed="false" spacing="15"
                  maxWidth="450" maxHeight="380"
                  style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20;
                         -fx-border-color: #2f6bff; -fx-border-width: 2;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 60, 0, 0, 0);">

                <Label text="Modifier la publication"/>

                <TextField fx:id="editTitleField"/>

                <TextArea fx:id="editContentField" prefHeight="140" wrapText="true"/>

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Annuler" onAction="#cancelEdit"/>
                    <Button text="Enregistrer" onAction="#updatePost"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>