<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="900.0" prefHeight="430.0"
            style="-fx-background-color: white;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cardiolink.Controllers.EnregistrerSuivi">

    <children>
        <VBox spacing="14.0" AnchorPane.topAnchor="25.0" AnchorPane.leftAnchor="35.0" AnchorPane.rightAnchor="35.0">
            <children>

                <Label text="Enregistrer un Nouveau Suivi"
                       style="-fx-text-fill: #1a1a2e; -fx-font-size: 28px; -fx-font-weight: bold;" />

                <Label text="Veuillez saisir uniquement le type de donnée et la valeur. Les autres informations seront remplies automatiquement."
                       wrapText="true"
                       style="-fx-text-fill: #444444; -fx-font-size: 16px;" />

                <VBox spacing="8">
                    <children>
                        <Label text="Type de donnée"
                               style="-fx-text-fill: #1a1a2e; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <ComboBox fx:id="cbTypeDonnee"
                                  prefHeight="48.0"
                                  prefWidth="700.0"
                                  promptText="Sélectionnez le type de donnée"
                                  style="-fx-background-color: #f5f5f5;
                                         -fx-text-fill: #1a1a2e;
                                         -fx-background-radius: 12;
                                         -fx-border-color: #d0d0d0;
                                         -fx-border-radius: 12;" />
                    </children>
                </VBox>

                <VBox spacing="8">
                    <children>
                        <Label text="Valeur mesurée"
                               style="-fx-text-fill: #1a1a2e; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <TextField fx:id="txtValeur"
                                   promptText="Ex: 120.5"
                                   prefHeight="48.0"
                                   style="-fx-background-color: #f5f5f5;
                                          -fx-text-fill: #1a1a2e;
                                          -fx-prompt-text-fill: #9aa7c7;
                                          -fx-background-radius: 12;
                                          -fx-border-color: #d0d0d0;
                                          -fx-border-radius: 12;" />
                    </children>
                </VBox>

                <Label fx:id="lblInfo"
                       text="Veuillez entrer une valeur numérique (ex: 120.5)"
                       style="-fx-text-fill: #444444; -fx-font-size: 14px;" />

                <HBox spacing="12">
                    <children>
                        <Button text="Enregistrer le Suivi"
                                onAction="#enregistrerSuivi"
                                prefWidth="240.0"
                                prefHeight="52.0"
                                style="-fx-background-color: linear-gradient(to right, #ff5f8f, #7b8dff);
                                       -fx-text-fill: white;
                                       -fx-font-size: 18px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />

                        <Button text="Annuler"
                                onAction="#fermerFenetre"
                                prefWidth="130.0"
                                prefHeight="52.0"
                                style="-fx-background-color: #e0e0e0;
                                       -fx-text-fill: #1a1a2e;
                                       -fx-font-size: 18px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 14;
                                       -fx-cursor: hand;" />
                    </children>
                </HBox>

                <VBox spacing="8"
                      style="-fx-border-color: #2f6fff;
                             -fx-border-width: 0 0 0 3;
                             -fx-padding: 10 0 0 12;">
                    <children>
                        <Label text="Rappel Important"
                               style="-fx-text-fill: #1a1a2e; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <Label text="• L'unité de mesure sera définie automatiquement selon le type de donnée"
                               style="-fx-text-fill: #444444; -fx-font-size: 16px;" />
                        <Label text="• Le niveau d'urgence sera calculé automatiquement basé sur les valeurs critiques"
                               style="-fx-text-fill: #444444; -fx-font-size: 16px;" />
                        <Label text="• Si un seuil critique est détecté, une alerte d'urgence sera créée automatiquement"
                               style="-fx-text-fill: #444444; -fx-font-size: 16px;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>