<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="1280.0" prefHeight="720.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cardiolink.Controllers.MedecinDashboardController"
            style="-fx-background-color: linear-gradient(to bottom, #0d1030, #14173d);">

    <children>
        <VBox prefWidth="1280.0" prefHeight="720.0">

            <!-- NAVBAR -->
            <children>
                <HBox alignment="CENTER_LEFT" spacing="28.0"
                      prefHeight="72.0"
                      style="-fx-background-color: #0d1030; -fx-border-color: #2a2f63; -fx-border-width: 0 0 1 0; -fx-padding: 0 26 0 26;">
                    <children>

                        <Label text="❤  CardioLink"
                               style="-fx-text-fill: linear-gradient(to right, #ff5c8a, #7d86ff); -fx-font-size: 20px; -fx-font-weight: bold;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="Home"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="Community"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="Interventions"
                                onAction="#ouvrirInterventions"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" />

                        <Button text="SOS"
                                onAction="#ouvrirAlertesSOS"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="Gérer RDV"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="Mon Profil"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="Logout"
                                onAction="#logout"
                                style="-fx-background-color: transparent; -fx-text-fill: #d4d7f0; -fx-font-size: 16px; -fx-cursor: hand;" />

                        <Button text="☾"
                                prefWidth="72.0"
                                prefHeight="42.0"
                                style="-fx-background-color: linear-gradient(to right, #1b1f4a, #22295f);
                                       -fx-text-fill: #ffb86b;
                                       -fx-font-size: 20px;
                                       -fx-background-radius: 14;
                                       -fx-border-color: #3b4288;
                                       -fx-border-radius: 14;
                                       -fx-cursor: hand;" />
                    </children>
                </HBox>

                <!-- HERO -->
                <HBox spacing="40.0" VBox.vgrow="ALWAYS" style="-fx-padding: 55 50 40 50;">
                    <children>

                        <!-- LEFT -->
                        <VBox spacing="22.0" prefWidth="560.0">
                            <children>
                                <Label text="Welcome to CardioLink" wrapText="true">
                                    <font>
                                        <Font size="54.0" />
                                    </font>
                                    <style>
                                        -fx-text-fill: white;
                                        -fx-font-weight: bold;
                                    </style>
                                </Label>

                                <Label text="Your comprehensive cardiac health management platform. Monitor, track, and manage your cardiovascular health with ease. Making healthcare smarter, faster, and more accessible for everyone."
                                       wrapText="true"
                                       maxWidth="560.0"
                                       style="-fx-text-fill: #d7daf0; -fx-font-size: 20px; -fx-line-spacing: 8px;" />

                                <HBox spacing="16.0">
                                    <children>
                                        <Button text="View Dashboard"
                                                onAction="#ouvrirInterventions"
                                                prefWidth="210.0"
                                                prefHeight="58.0"
                                                style="-fx-background-color: linear-gradient(to right, #ff5a7c, #7f82ff);
                                                       -fx-text-fill: white;
                                                       -fx-font-size: 18px;
                                                       -fx-font-weight: bold;
                                                       -fx-background-radius: 18;
                                                       -fx-cursor: hand;" />

                                        <Button text="Community"
                                                prefWidth="170.0"
                                                prefHeight="58.0"
                                                style="-fx-background-color: transparent;
                                                       -fx-text-fill: white;
                                                       -fx-font-size: 18px;
                                                       -fx-font-weight: bold;
                                                       -fx-border-color: #2f5b9a;
                                                       -fx-border-radius: 18;
                                                       -fx-background-radius: 18;
                                                       -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- RIGHT -->
                        <StackPane prefWidth="510.0" prefHeight="430.0"
                                   style="-fx-background-color: linear-gradient(to bottom right, rgba(88,42,76,0.7), rgba(50,53,105,0.75));
                                          -fx-background-radius: 26;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 28, 0.2, 0, 12);">
                            <children>

                                <StackPane prefWidth="280.0" prefHeight="280.0"
                                           style="-fx-background-color: rgba(130, 95, 170, 0.16); -fx-background-radius: 999;">
                                    <children>
                                        <StackPane prefWidth="200.0" prefHeight="200.0"
                                                   style="-fx-background-color: rgba(130, 95, 170, 0.14); -fx-background-radius: 999;">
                                            <children>
                                                <StackPane prefWidth="130.0" prefHeight="130.0"
                                                           style="-fx-background-color: rgba(130, 95, 170, 0.16); -fx-background-radius: 999;">
                                                    <children>
                                                        <Label text="❤"
                                                               style="-fx-text-fill: linear-gradient(to bottom, #ff6b87, #ff2f67); -fx-font-size: 60px;" />
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </StackPane>
                                    </children>
                                </StackPane>

                            </children>
                        </StackPane>
                    </children>
                </HBox>

                <HBox style="-fx-padding: 0 50 0 50;">
                    <children>
                        <Region prefHeight="1.0" HBox.hgrow="ALWAYS"
                                style="-fx-background-color: #2d356d;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>