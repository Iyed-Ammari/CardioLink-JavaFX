<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="450.0" styleClass="root" stylesheets="@chat-style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cardiolink.Controllers.ChatController">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="chat-header">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;" text="CardioLink - Messagerie" />
            </children>
        </HBox>

        <ListView fx:id="messageListView" styleClass="chat-list" VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="10.0" styleClass="chat-input-container">
            <children>
                <TextField fx:id="messageInput" onAction="#handleSendMessage" promptText="Écrivez un message..." styleClass="chat-input" HBox.hgrow="ALWAYS" />
                <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="35.0" prefWidth="80.0" styleClass="send-button" text="Envoyer" />
            </children>
        </HBox>
    </children>
</VBox>