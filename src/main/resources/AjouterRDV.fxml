<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="680.0" prefWidth="600.0" stylesheets="@css/rdv_style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cardiolink.Controllers.AjouterRDV">
    <children>
        <VBox alignment="CENTER" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="main-container">
            <children>
                <VBox spacing="5.0" alignment="CENTER">
                    <children>
                        <Label fx:id="titleLabel" styleClass="title-text" text="Prendre un Rendez-vous" />
                        <Label styleClass="subtitle-text" text="Réservez votre consultation en quelques clics" />
                    </children>
                </VBox>

                <VBox spacing="20.0" styleClass="glass-pane" style="-fx-padding: 30;">
                    <children>
                        <VBox spacing="8.0">
                            <Label styleClass="label-text" text="Médecin spécialisé" />
                            <ComboBox fx:id="medecin" maxWidth="Infinity" prefHeight="45.0" promptText="Sélectionner un praticien" />
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-text" text="Date de visite" />
                                    <DatePicker fx:id="date" maxWidth="Infinity" prefHeight="45.0" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label styleClass="label-text" text="Créneau horaire" />
                                    <ComboBox fx:id="heure" maxWidth="Infinity" prefHeight="45.0" />
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label styleClass="label-text" text="Type de consultation" />
                            <ComboBox fx:id="type" maxWidth="Infinity" prefHeight="45.0" />
                        </VBox>

                        <VBox spacing="8.0">
                            <Label styleClass="label-text" text="Notes ou symptômes" />
                            <TextArea fx:id="remarques" prefHeight="100.0" promptText="Décrivez brièvement le motif de votre visite..." wrapText="true" />
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#save" prefHeight="55.0" prefWidth="400.0" styleClass="gradient-button" text="Confirmer la réservation" />
                        
                        <HBox alignment="CENTER" spacing="20.0">
                           <children>
                               <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="action-button, delete-button" text="Annuler" />
                               <Button mnemonicParsing="false" onAction="#goToMenu" styleClass="action-button" text="🏠 Accueil" />
                           </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>