<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cardiolink.Controllers.ChatControllerAdvanced"
      styleClass="root-adv"
      stylesheets="@chat_advanced.css"
      prefWidth="1100.0"
      prefHeight="680.0">

    <!-- ══════════════════════════════════════════════════════════════
         PANNEAU GAUCHE — Conversations
    ══════════════════════════════════════════════════════════════════ -->
    <VBox fx:id="leftPanel"
          styleClass="left-panel"
          prefWidth="290.0"
          minWidth="260.0"
          maxWidth="300.0">

        <!-- Header : Titre + Badge notifications globales -->
        <HBox styleClass="conv-header" alignment="CENTER_LEFT" spacing="10.0">
            <Label text="💬 Messagerie" styleClass="conv-title"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <!-- Bouton pour créer une conversation -->
            <Button text="+" styleClass="new-conv-btn" onAction="#handleNewConversation">
                <tooltip>
                    <Tooltip text="Nouvelle conversation" />
                </tooltip>
            </Button>
            <Label fx:id="globalNotifBadge"
                   text="0"
                   styleClass="notif-badge"
                   visible="false"
                   managed="false"/>
        </HBox>

        <!-- Recherche + Tri -->
        <VBox spacing="8.0" style="-fx-padding: 10 14 6 14;">
            <TextField fx:id="searchField"
                       promptText="🔍 Rechercher un contact..."
                       styleClass="search-field"
                       onKeyReleased="#handleSearch"/>
            <HBox spacing="6.0" alignment="CENTER_LEFT">
                <Label text="Trier :" style="-fx-text-fill:#5a7080; -fx-font-size:12px;"/>
                <ComboBox fx:id="sortCombo"
                          styleClass="sort-combo"
                          prefWidth="110.0"
                          onAction="#handleSort">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Récent"/>
                            <String fx:value="Créé"/>
                            <String fx:value="Contact"/>
                            <String fx:value="Statut"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ToggleButton fx:id="sortOrderBtn"
                              text="↓"
                              styleClass="filter-btn"
                              onAction="#handleSortOrder"
                              prefWidth="34.0"/>
            </HBox>
        </VBox>

        <!-- Liste des conversations -->
        <ListView fx:id="convList"
                  styleClass="conv-list"
                  VBox.vgrow="ALWAYS"
                  onMouseClicked="#handleConvSelected"/>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════════
         PANNEAU DROIT — Zone de Chat
    ══════════════════════════════════════════════════════════════════ -->
    <VBox fx:id="rightPanel"
          styleClass="right-panel"
          HBox.hgrow="ALWAYS">

        <!-- Header contact -->
        <HBox fx:id="chatHeaderBox"
              styleClass="chat-header-adv"
              alignment="CENTER_LEFT"
              spacing="12.0">

            <Button fx:id="backButton"
                    text="←"
                    styleClass="back-btn-adv"
                    onAction="#handleBackButton"/>

            <!-- Avatar contact -->
            <Label fx:id="contactAvatar"
                   text="?"
                   styleClass="conv-avatar, avatar-patient"
                   style="-fx-min-width:42px; -fx-min-height:42px; -fx-max-width:42px; -fx-max-height:42px;
                          -fx-background-radius:21px; -fx-alignment:center; -fx-font-size:18px;
                          -fx-font-weight:bold; -fx-text-fill:white; -fx-background-color:#0077b6;"/>

            <!-- Nom + statut -->
            <VBox spacing="2.0">
                <Label fx:id="contactNameLabel" text="Sélectionnez une conversation"
                       styleClass="contact-name"/>
                <Label fx:id="contactStatusLabel" text="" styleClass="contact-status"/>
                <Label fx:id="typingLabel" text="" styleClass="typing-indicator" visible="false" managed="false"/>
            </VBox>

            <HBox HBox.hgrow="ALWAYS"/>

            <!-- Notifications non lues de cette conversation -->
            <VBox alignment="CENTER" spacing="4.0">
                <Label fx:id="convNotifCount"
                       text=""
                       styleClass="notif-badge"
                       visible="false"
                       managed="false"/>
            </VBox>
        </HBox>

        <!-- Barre de filtres messages -->
        <HBox fx:id="filterBar" styleClass="filter-bar" alignment="CENTER_LEFT" spacing="8.0">
            <Button fx:id="filterAll"      text="Tous"      styleClass="filter-btn-active" onAction="#handleFilterAll"/>
            <Button fx:id="filterPinned"   text="📌 Épinglés"  styleClass="filter-btn"   onAction="#handleFilterPinned"/>
            <Button fx:id="filterArchived" text="🗄 Archivés"  styleClass="filter-btn"   onAction="#handleFilterArchived"/>
            <Button fx:id="filterUrgent"   text="🔴 Urgents"   styleClass="filter-btn"   onAction="#handleFilterUrgent"/>

            <HBox HBox.hgrow="ALWAYS"/> <!-- Pousse la recherche à droite -->

            <!-- NOUVEAUTÉ : Barre de recherche dans la conversation -->
            <TextField fx:id="messageSearchField"
                       promptText="🔍 Chercher un message..."
                       styleClass="search-field"
                       onKeyReleased="#handleMessageSearch"
                       prefWidth="190.0"/>
        </HBox>

        <!-- Zone messages -->
        <ListView fx:id="messageListView"
                  styleClass="msg-list-adv"
                  VBox.vgrow="ALWAYS"/>

        <!-- Zone suggestions intelligentes -->
        <HBox fx:id="suggestionBar"
              styleClass="suggestion-bar"
              alignment="CENTER_LEFT"
              visible="false"
              managed="false">
            <Label text="💡" styleClass="suggestion-label" style="-fx-font-size:14px;"/>
            <Label text="Suggestions :" styleClass="suggestion-label"/>
            <Button fx:id="suggestion1" text="" styleClass="suggestion-btn" onAction="#handleSuggestion1" visible="false" managed="false"/>
            <Button fx:id="suggestion2" text="" styleClass="suggestion-btn" onAction="#handleSuggestion2" visible="false" managed="false"/>
            <Button fx:id="suggestion3" text="" styleClass="suggestion-btn" onAction="#handleSuggestion3" visible="false" managed="false"/>
        </HBox>

        <!-- Zone saisie -->
        <VBox styleClass="input-area" spacing="8.0">

            <!-- Ligne classification -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Type :" style="-fx-text-fill:#5a7080; -fx-font-size:12px;"/>
                <ComboBox fx:id="classificationCombo"
                          styleClass="classify-combo"
                          prefWidth="140.0">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="AUTO 🤖"/>
                            <String fx:value="NORMAL"/>
                            <String fx:value="URGENT"/>
                            <String fx:value="ADMINISTRATIF"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <!-- Ligne input + envoi -->
            <HBox alignment="CENTER" spacing="8.0">
                <Button fx:id="emojiPickerBtn"
                        text="😊"
                        styleClass="emoji-toggle-btn"
                        onAction="#handleEmojiPickerToggle"/>

                <TextField fx:id="messageInput"
                           promptText="Écrivez un message..."
                           styleClass="msg-input-adv"
                           HBox.hgrow="ALWAYS"
                           onAction="#handleSendMessage"
                           onKeyReleased="#handleTyping"/>

                <Button fx:id="sendButton"
                        text="Envoyer ▶"
                        styleClass="send-btn-adv"
                        onAction="#handleSendMessage"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>