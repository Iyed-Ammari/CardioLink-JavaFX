<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cardiolink.Controllers.AdminDashboardController"
           prefWidth="1100" prefHeight="650"
           style="-fx-background-color: #f8f8ff;">

    <!-- WELCOME PAGE -->
    <ScrollPane fx:id="welcomeView" fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="0" style="-fx-background-color: #eef0fb;">

            <HBox alignment="CENTER" spacing="50"
                  style="-fx-padding: 80 80 60 80; -fx-background-color: #eef0fb;">
                <VBox spacing="22" HBox.hgrow="ALWAYS" maxWidth="500">
                    <Label fx:id="welcomeName" text="Welcome to CardioLink"
                           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <Label text="Your comprehensive cardiac health management platform. Monitor, track, and manage your cardiovascular health with ease. Making healthcare smarter, faster, and more accessible for everyone."
                           wrapText="true"
                           style="-fx-font-size: 14px; -fx-text-fill: #555; -fx-line-spacing: 5;"/>
                    <HBox spacing="16" style="-fx-padding: 10 0 0 0;">
                        <Button text="View Dashboard" onAction="#goToDashboard"
                                style="-fx-background-color: linear-gradient(to right, #E24B4A, #7F77DD);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 14 30; -fx-background-radius: 30; -fx-cursor: hand;"/>
                        <Button text="Community"
                                style="-fx-background-color: transparent; -fx-text-fill: #333;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-padding: 14 30; -fx-background-radius: 30; -fx-cursor: hand;
                                       -fx-border-color: #bbb; -fx-border-radius: 30; -fx-border-width: 1.5;"/>
                    </HBox>
                </VBox>

                <StackPane minWidth="270" minHeight="270" prefWidth="270" prefHeight="270"
                           style="-fx-background-color: linear-gradient(to bottom right, #e8e2ff, #f5e8ff);
                                  -fx-background-radius: 28;">
                    <Circle radius="110" fill="#ddd5f8"/>
                    <Circle radius="82"  fill="#c8baf0"/>
                    <Circle radius="56"  fill="#9880e0"/>
                    <Label text="❤" style="-fx-font-size: 32px; -fx-text-fill: white;"/>
                </StackPane>
            </HBox>

            <VBox spacing="20" style="-fx-padding: 0 80 70 80; -fx-background-color: #eef0fb;">
                <Label text="Why Choose CardioLink?"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <HBox spacing="20">
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 28 22;
                                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),12,0,0,4);">
                        <Label text="🩺" style="-fx-font-size: 28px;"/>
                        <Label text="Expert Care"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Connect with certified cardiologists and specialists who provide personalized care plans tailored to your heart health needs."
                               wrapText="true"
                               style="-fx-font-size: 12.5px; -fx-text-fill: #666; -fx-line-spacing: 3;"/>
                    </VBox>
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 28 22;
                                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),12,0,0,4);">
                        <Label text="📈" style="-fx-font-size: 28px;"/>
                        <Label text="Health Tracking"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Monitor your vital signs, track medications, and visualize your health progress with intuitive dashboards and real-time insights."
                               wrapText="true"
                               style="-fx-font-size: 12.5px; -fx-text-fill: #666; -fx-line-spacing: 3;"/>
                    </VBox>
                    <VBox spacing="10" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-padding: 28 22;
                                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),12,0,0,4);">
                        <Label text="🚨" style="-fx-font-size: 28px;"/>
                        <Label text="Emergency SOS"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="One-tap emergency alerts notify your care team and loved ones instantly, ensuring rapid response when every second counts."
                               wrapText="true"
                               style="-fx-font-size: 12.5px; -fx-text-fill: #666; -fx-line-spacing: 3;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- DASHBOARD (sidebar + content) -->
    <BorderPane fx:id="dashboardPane" visible="false"
                style="-fx-background-color: #f8f8ff;">

        <!-- SIDEBAR -->
        <left>
            <VBox spacing="0" minWidth="220"
                  style="-fx-background-color: #1a1a2e; -fx-padding: 0;">

                <HBox alignment="CENTER" spacing="8"
                      style="-fx-padding: 24 20 20 20; -fx-border-color: #2a2a4e; -fx-border-width: 0 0 1 0;">
                    <Label text="❤" style="-fx-text-fill: #E24B4A; -fx-font-size: 20px;"/>
                    <Label text="CardioLink"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </HBox>

                <VBox alignment="CENTER" spacing="6"
                      style="-fx-padding: 20 20 16 20; -fx-border-color: #2a2a4e; -fx-border-width: 0 0 1 0;">
                    <StackPane>
                        <Circle radius="28" fill="linear-gradient(to bottom right, #E24B4A, #7F77DD)"/>
                        <Label fx:id="sidebarInitial" text="A"
                               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20px;"/>
                    </StackPane>
                    <Label fx:id="sidebarName" text="Admin"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Administrateur"
                           style="-fx-text-fill: #7F77DD; -fx-font-size: 11px;"/>
                </VBox>

                <VBox spacing="4" style="-fx-padding: 16 12;">
                    <Button text="🏠  Accueil" onAction="#showWelcomePage"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-text-fill: #ccc;
                                   -fx-font-size: 13px; -fx-padding: 12 16; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                    <Button fx:id="btnHome" text="📊  Dashboard" onAction="#showHome"
                            maxWidth="Infinity"
                            style="-fx-background-color: #7F77DD; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-padding: 12 16; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                    <Button fx:id="btnUsers" text="👥  Utilisateurs" onAction="#showUsers"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-text-fill: #ccc;
                                   -fx-font-size: 13px; -fx-padding: 12 16; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                    <Button fx:id="btnDossiers" text="🗂  Dossiers Médicaux" onAction="#showDossiers"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-text-fill: #ccc;
                                   -fx-font-size: 13px; -fx-padding: 12 16; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="🚪  Déconnexion" onAction="#handleLogout"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b;
                               -fx-font-size: 13px; -fx-padding: 14 16; -fx-cursor: hand;
                               -fx-alignment: CENTER_LEFT;"/>
            </VBox>
        </left>

        <!-- MAIN CONTENT -->
        <center>
            <StackPane style="-fx-background-color: #f8f8ff;">

                <!-- HOME VIEW -->
                <ScrollPane fx:id="homeView" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="30" style="-fx-padding: 40;">
                        <Label text="📊  Tableau de Bord Admin"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <HBox spacing="20">
                            <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28 20;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);">
                                <Label text="🧑‍⚕️" style="-fx-font-size: 32px;"/>
                                <Label fx:id="countPatients" text="0"
                                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #7F77DD;"/>
                                <Label text="Patients" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28 20;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);">
                                <Label text="👨‍⚕️" style="-fx-font-size: 32px;"/>
                                <Label fx:id="countMedecins" text="0"
                                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #E24B4A;"/>
                                <Label text="Médecins" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28 20;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);">
                                <Label text="📅" style="-fx-font-size: 32px;"/>
                                <Label fx:id="countSignins" text="0"
                                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                <Label text="Inscriptions ce mois" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="12">
                            <Label text="Actions rapides"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <HBox spacing="12">
                                <Button text="👥  Gérer les utilisateurs" onAction="#showUsers"
                                        style="-fx-background-color: linear-gradient(to right, #7F77DD, #E24B4A);
                                               -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                               -fx-padding: 12 24; -fx-background-radius: 20; -fx-cursor: hand;"/>
                                <Button text="🗂  Voir les dossiers médicaux" onAction="#showDossiers"
                                        style="-fx-background-color: white; -fx-text-fill: #333;
                                               -fx-font-size: 13px; -fx-font-weight: bold;
                                               -fx-padding: 12 24; -fx-background-radius: 20; -fx-cursor: hand;
                                               -fx-border-color: #ddd; -fx-border-radius: 20; -fx-border-width: 1.5;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>

                <!-- USERS VIEW -->
                <ScrollPane fx:id="usersView" fitToWidth="true" visible="false"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="20" style="-fx-padding: 40;">
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <Label text="👥  Gestion des Utilisateurs"
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="➕  Ajouter un utilisateur" onAction="#goAddUser"
                                    style="-fx-background-color: linear-gradient(to right, #E24B4A, #7F77DD);
                                           -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-padding: 10 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField" promptText="Rechercher nom, prénom, email..."
                                       prefWidth="300"
                                       style="-fx-background-color: white; -fx-border-color: #ddd;
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-padding: 8 14; -fx-font-size: 13px;"/>
                            <ComboBox fx:id="roleFilter"
                                      style="-fx-background-color: white; -fx-border-color: #ddd;
                                             -fx-border-radius: 8; -fx-font-size: 13px;"/>
                            <Button text="🔍  Rechercher" onAction="#handleSearch"
                                    style="-fx-background-color: #7F77DD; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-padding: 8 18;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                        <TableView fx:id="usersTable" prefHeight="400"
                                   style="-fx-background-color: white; -fx-background-radius: 12;
                                          -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,3);">
                            <columns>
                                <TableColumn fx:id="colNom"     text="Nom"     prefWidth="100"/>
                                <TableColumn fx:id="colPrenom"  text="Prénom"  prefWidth="100"/>
                                <TableColumn fx:id="colEmail"   text="Email"   prefWidth="200"/>
                                <TableColumn fx:id="colRole"    text="Rôle"    prefWidth="90"/>
                                <TableColumn fx:id="colStatut"  text="Statut"  prefWidth="80"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="320"/>
                            </columns>
                        </TableView>
                    </VBox>
                </ScrollPane>

                <!-- DOSSIERS VIEW -->
                <ScrollPane fx:id="dossiersView" fitToWidth="true" visible="false"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="20" style="-fx-padding: 40;">
                        <Label text="🗂  Dossiers Médicaux"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <TableView fx:id="dossiersTable" prefHeight="500"
                                   style="-fx-background-color: white; -fx-background-radius: 12;
                                          -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,3);">
                            <columns>
                                <TableColumn fx:id="dColPatient" text="Patient"         prefWidth="150"/>
                                <TableColumn fx:id="dColGroupe"  text="Groupe Sanguin"  prefWidth="110"/>
                                <TableColumn fx:id="dColPoids"   text="Poids (kg)"      prefWidth="90"/>
                                <TableColumn fx:id="dColTaille"  text="Taille (cm)"     prefWidth="90"/>
                                <TableColumn fx:id="dColTenSys"  text="T. Systolique"   prefWidth="110"/>
                                <TableColumn fx:id="dColTenDia"  text="T. Diastolique"  prefWidth="110"/>
                                <TableColumn fx:id="dColFreq"    text="Fréq. Cardiaque" prefWidth="120"/>
                                <TableColumn fx:id="dColActions" text="Actions"         prefWidth="220"/>
                            </columns>
                        </TableView>
                    </VBox>
                </ScrollPane>

            </StackPane>
        </center>
    </BorderPane>

</StackPane>