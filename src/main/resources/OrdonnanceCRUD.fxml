<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" 
            stylesheets="@css/rdv_style.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cardiolink.Controllers.AjouterOrdonnance">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" styleClass="navbar">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="navbar-brand-heart" text="❤" />
                <Label styleClass="navbar-brand-text" text="CardioLink" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goHome" styleClass="nav-button" text="🏠 Home" />
            <Button onAction="#goCommunity" styleClass="nav-button" text="👥 Community" />
            <Button onAction="#goSuivis" styleClass="nav-button" text="📊 Mes Suivis" />
            <Button onAction="#goRDV" styleClass="nav-button" text="📅 Mes RDV" />
            <Button onAction="#goDossier" styleClass="nav-button" text="🗂 Mon Dossier" />
            <Button onAction="#goProfil" styleClass="nav-button" text="👤 Mon Profil" />
            <Button onAction="#handleLogout" styleClass="nav-button, nav-logout" text="🚪 Logout" />
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18" styleClass="avatar-circle" />
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="?" />
            </StackPane>
        </HBox>
    </top>

    <center>
        <HBox spacing="0.0">
            <children>
                <!-- Preview Panel -->
                <VBox prefWidth="350.0" style="-fx-background-color: white; -fx-border-color: #ececec; -fx-border-width: 0 1 0 0;" spacing="25.0">
                    <padding><Insets bottom="40.0" left="30.0" right="30.0" top="40.0" /></padding>
                    <children>
                        <Label styleClass="subtitle-text" text="Aperçu Rapide" />
                        <VBox spacing="15.0" styleClass="card" style="-fx-background-color: #f8f8ff;">
                            <children>
                                <Label fx:id="lblPreviewRef" styleClass="label-text" text="REF: ----" style="-fx-font-size: 16px;" />
                                <Line endX="200.0" stroke="#ececec" />
                                <Label styleClass="label-text" text="DIAGNOSTIC :" style="-fx-text-fill: #888;" />
                                <Label fx:id="lblPreviewDiag" styleClass="label-text" text="En attente..." wrapText="true" />
                                <Label styleClass="label-text" text="PRESCRIPTION :" style="-fx-text-fill: #888;">
                                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                                </Label>
                                <Label fx:id="lblPreviewPrescr" styleClass="label-text" text="..." wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Form Panel -->
                <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox spacing="30.0" styleClass="content-area">
                        <children>
                            <Label styleClass="title-text" text="Détails de l'ordonnance" />

                            <VBox spacing="20.0" styleClass="card">
                                <children>
                                    <VBox spacing="8.0">
                                        <Label styleClass="label-text" text="Référence" />
                                        <TextField fx:id="txtReference" promptText="Ex: ORD-2024-001" />
                                    </VBox>
                                    <VBox spacing="8.0">
                                        <Label styleClass="label-text" text="Diagnostic" />
                                        <TextArea fx:id="txtDiagnostic" prefHeight="100.0" promptText="Saisir le diagnostic..." wrapText="true" />
                                    </VBox>
                                    <VBox spacing="8.0">
                                        <Label styleClass="label-text" text="Prescription / Médicaments" />
                                        <TextArea fx:id="txtPrescription" prefHeight="150.0" promptText="Détails des médicaments..." wrapText="true" />
                                    </VBox>
                                </children>
                            </VBox>

                            <HBox spacing="12.0" alignment="CENTER_RIGHT">
                                <children>
                                    <Button onAction="#goToAfficher" styleClass="action-button" text="Annuler" />
                                    <Button onAction="#clearFields" styleClass="action-button" text="Réinitialiser" />
                                    <Button fx:id="btnDelete" visible="false" onAction="#handleDelete" styleClass="action-button, delete-button" text="Supprimer" />
                                    <Button fx:id="btnPdf" visible="false" onAction="#handleGeneratePdf" styleClass="action-button" text="📄 PDF" style="-fx-border-color: #f39c12; -fx-text-fill: #f39c12;" />
                                    <Button fx:id="btnSave" onAction="#handleSave" styleClass="gradient-button" text="Générer &amp; Enregistrer" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </ScrollPane>
            </children>
        </HBox>
    </center>
</BorderPane>

