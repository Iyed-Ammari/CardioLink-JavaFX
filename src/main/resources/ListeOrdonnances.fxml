<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" 
            stylesheets="@css/rdv_style.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.cardiolink.Controllers.ListeOrdonnances">

    <!-- NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" styleClass="navbar">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="navbar-brand-heart" text="❤" />
                <Label styleClass="navbar-brand-text" text="CardioLink" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goHome" styleClass="nav-button" text="🏠 Home" />
            <Button onAction="#goCommunity" styleClass="nav-button" text="👥 Community" />
            <Button onAction="#goSuivis" styleClass="nav-button" text="📊 Mes Suivis" />
            <Button onAction="#goRDV" styleClass="nav-button" text="📅 Mes RDV" />
            <Button onAction="#goDossier" styleClass="nav-button" text="🗂 Mon Dossier" />
            <Button onAction="#goProfil" styleClass="nav-button" text="👤 Mon Profil" />
            <Button onAction="#handleLogout" styleClass="nav-button, nav-logout" text="🚪 Logout" />
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18" styleClass="avatar-circle" />
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="?" />
            </StackPane>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="25.0" styleClass="content-area">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                            <VBox HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="subtitle-text" text="Gestion Médicale" />
                                    <Label styleClass="title-text" text="Gestion des Ordonnances" />
                                </children>
                            </VBox>
                            <Button fx:id="btnAjouter" onAction="#goToAdd" styleClass="gradient-button" text="+ Nouvelle Ordonnance" />
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card">
                        <children>
                            <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                                <Label styleClass="label-text" text="Rechercher" />
                                <TextField fx:id="searchField" onKeyReleased="#onSearch" promptText="Référence, nom du patient..." />
                            </VBox>
                        </children>
                    </HBox>

                    <TableView fx:id="tableOrdonnances" prefHeight="400.0" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colRef" prefWidth="150.0" text="Référence" />
                            <TableColumn fx:id="colDate" prefWidth="180.0" text="Date" />
                            <TableColumn fx:id="colPatient" prefWidth="250.0" text="Patient" />
                            <TableColumn fx:id="colDiag" prefWidth="350.0" text="Diagnostic" />
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="15.0">
                        <children>
                            <Label fx:id="lblTotal" styleClass="subtitle-text" text="0 ordonnances trouvées" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnModifier" onAction="#handleEdit" styleClass="action-button" text="Modifier" />
                            <Button fx:id="btnSupprimer" onAction="#handleDelete" styleClass="action-button, delete-button" text="Supprimer" />
                        </children>
                    </HBox>
                </children>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>