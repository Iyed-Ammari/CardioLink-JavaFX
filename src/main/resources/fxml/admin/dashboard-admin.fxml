<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.Controllers.AdminDashboardController">

    <left>
        <VBox spacing="16" prefWidth="290"
              style="-fx-background-color: white; -fx-padding: 22 18 18 18; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, #F82239, #2F60F5); -fx-background-radius: 14;">
                    <Label text="CL" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="CardioLink" style="-fx-text-fill: #111827; -fx-font-size: 18px; -fx-font-weight: 800;"/>
                    <Label text="Admin · Marketplace" style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="🏠  Dashboard" onAction="#goToDashboard" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="📦  Produits" onAction="#goToProduits" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="📋  Commandes" onAction="#goToCommandes" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="🤖  Prédiction IA" onAction="#goToPredictionIA" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 14 0 0 0; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, rgba(248,34,57,0.22), rgba(47,96,245,0.22)); -fx-background-radius: 16;">
                    <Label fx:id="sidebarInitial" text="?" style="-fx-text-fill: #1F2937; -fx-font-weight: 900;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="sidebarNom" text="—" style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                    <Label fx:id="sidebarRole" text="—" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-background-color: #F6F7FB; -fx-padding: 28;">

            <VBox spacing="6"
                  style="-fx-background-color: #0D0F14; -fx-background-radius: 18; -fx-padding: 16 24;">
                <Label text="CardioLink · Espace Admin"
                       style="-fx-text-fill: rgba(255,255,255,0.45); -fx-font-size: 11px; -fx-font-weight: 700;"/>
                <Label fx:id="heroTitleLabel" text="Tableau de bord"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 800;"/>
                <Label fx:id="heroSubtitleLabel" text="Vue d'ensemble de la marketplace CardioLink"
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-font-weight: 600;"/>
            </VBox>

            <HBox spacing="14">
                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #E5E7EB; -fx-border-radius: 18; -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#goToProduits">
                    <Label text="📦  Produits" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    <Label fx:id="totalProduitsLabel" text="—"
                           style="-fx-text-fill: #111827; -fx-font-size: 32px; -fx-font-weight: 900;"/>
                    <Label text="dans le catalogue" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;"/>
                    <Label fx:id="ruptureBadge" text=""
                           style="-fx-text-fill: #DC2626; -fx-font-size: 11px; -fx-font-weight: 700;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #E5E7EB; -fx-border-radius: 18; -fx-padding: 20;">
                    <Label text="💰  Chiffre d'affaires" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    <Label fx:id="caLabel" text="—"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                    <Label text="commandes payées + livrées" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;"/>
                </VBox>

                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #E5E7EB; -fx-border-radius: 18; -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#goToCommandes">
                    <Label text="📋  Commandes totales" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                    <Label fx:id="totalCommandesLabel" text="—"
                           style="-fx-text-fill: #2F60F5; -fx-font-size: 32px; -fx-font-weight: 900;"/>
                    <Label text="hors paniers" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <HBox spacing="14">
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(245,158,11,0.35); -fx-border-radius: 16; -fx-padding: 16;">
                    <Label text="⏳ En attente" style="-fx-text-fill: #B45309; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                    <Label fx:id="nbAttenteLabel" text="—" style="-fx-text-fill: #B45309; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(16,185,129,0.35); -fx-border-radius: 16; -fx-padding: 16;">
                    <Label text="💳 Payées" style="-fx-text-fill: #0F766E; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                    <Label fx:id="nbPayeesLabel" text="—" style="-fx-text-fill: #0F766E; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(47,96,245,0.35); -fx-border-radius: 16; -fx-padding: 16;">
                    <Label text="📦 Livrées" style="-fx-text-fill: #2F60F5; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                    <Label fx:id="nbLivreesLabel" text="—" style="-fx-text-fill: #2F60F5; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(248,34,57,0.25); -fx-border-radius: 16; -fx-padding: 16;">
                    <Label text="❌ Annulées" style="-fx-text-fill: #DC2626; -fx-font-size: 12px; -fx-font-weight: 800;"/>
                    <Label fx:id="nbAnnuleesLabel" text="—" style="-fx-text-fill: #DC2626; -fx-font-size: 26px; -fx-font-weight: 900;"/>
                </VBox>
            </HBox>

            <HBox spacing="14">
                <Button text="+ Ajouter un produit" onAction="#goToAjouterProduit"
                        prefHeight="44"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 12; -fx-padding: 10 22; -fx-cursor: hand;"/>
                <Button text="📋 Voir toutes les commandes" onAction="#goToCommandes"
                        prefHeight="44"
                        style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <Button text="🤖 Prédiction IA" onAction="#goToPredictionIA"
                        prefHeight="44"
                        style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;"/>
                <Button text="🔄 Actualiser" onAction="#handleRefresh"
                        prefHeight="44"
                        style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>