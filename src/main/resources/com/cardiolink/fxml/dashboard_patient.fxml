<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.controllers.PatientDashboardController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-color: #f8f8ff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
              style="-fx-background-color: white; -fx-padding: 14 30;
                     -fx-border-color: #ececec; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="❤" style="-fx-text-fill: #E24B4A; -fx-font-size: 22px;"/>
                <Label text="CardioLink"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🏠 Home" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"/>
            <Button text="👥 Community" onAction="#goCommunity"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"/>
            <!-- Boutons patient uniquement -->
            <Button fx:id="btnSuivis" text="📊 Mes Suivis" onAction="#goSuivis"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"/>
            <Button fx:id="btnDossier" text="🗂 Mon Dossier Médical" onAction="#goDossier"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"/>
            <!-- Commun -->
            <Button text="👤 Mon Profil" onAction="#goProfil"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"/>
            <Button text="🚪 Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #888;"/>
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18"
                        fill="linear-gradient(to bottom right, #E24B4A, #7F77DD)"/>
                <Label fx:id="avatarLabel" text="?"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </StackPane>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="40" style="-fx-padding: 60 80;">

                <HBox alignment="CENTER" spacing="60">
                    <VBox alignment="CENTER_LEFT" spacing="16" maxWidth="500">
                        <Label fx:id="welcomeLabel" text="Welcome to CardioLink"
                               style="-fx-font-size: 36px; -fx-font-weight: bold;
                                      -fx-text-fill: #1a1a2e; -fx-wrap-text: true;"/>
                        <Label text="Your comprehensive cardiac health management platform. Monitor, track, and manage your cardiovascular health with ease. Making healthcare smarter, faster, and more accessible for everyone."
                               wrapText="true"
                               style="-fx-font-size: 14px; -fx-text-fill: #555; -fx-line-spacing: 4;"/>
                        <HBox spacing="16" style="-fx-padding: 10 0 0 0;">
                            <Button text="View Dashboard" onAction="#viewDashboard"
                                    style="-fx-background-color: linear-gradient(to right, #E24B4A, #7F77DD);
                                           -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                                           -fx-padding: 12 28; -fx-background-radius: 25; -fx-cursor: hand;"/>
                            <Button text="Community" onAction="#goCommunity"
                                    style="-fx-background-color: white; -fx-text-fill: #333;
                                           -fx-font-size: 14px; -fx-font-weight: bold;
                                           -fx-padding: 12 28; -fx-background-radius: 25; -fx-cursor: hand;
                                           -fx-border-color: #ddd; -fx-border-radius: 25; -fx-border-width: 1.5;"/>
                        </HBox>
                    </VBox>

                    <StackPane minWidth="320" minHeight="300"
                               style="-fx-background-color: linear-gradient(to bottom right, #fce8ff, #e8e8ff);
                                      -fx-background-radius: 24;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 6);">
                        <VBox alignment="CENTER">
                            <StackPane>
                                <Circle radius="110" fill="rgba(200,190,255,0.25)"/>
                                <Circle radius="80"  fill="rgba(200,190,255,0.35)"/>
                                <Circle radius="55"  fill="rgba(200,190,255,0.5)"/>
                                <Label text="❤" style="-fx-font-size: 52px;"/>
                            </StackPane>
                        </VBox>
                    </StackPane>
                </HBox>

                <VBox alignment="CENTER" spacing="20">
                    <Label text="Why Choose CardioLink?"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                    <HBox spacing="24" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="10" minWidth="200" maxWidth="240"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-padding: 28 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                            <Label text="🩺" style="-fx-font-size: 36px;"/>
                            <Label text="Expert Care"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <Label text="Connect with top cardiologists and get expert medical advice."
                                   wrapText="true"
                                   style="-fx-font-size: 12px; -fx-text-fill: #777; -fx-text-alignment: center;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10" minWidth="200" maxWidth="240"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-padding: 28 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                            <Label text="📊" style="-fx-font-size: 36px;"/>
                            <Label text="Health Tracking"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <Label text="Monitor your vital signs and track your health progress."
                                   wrapText="true"
                                   style="-fx-font-size: 12px; -fx-text-fill: #777; -fx-text-alignment: center;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="10" minWidth="200" maxWidth="240"
                              style="-fx-background-color: white; -fx-background-radius: 16;
                                     -fx-padding: 28 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);">
                            <Label text="🚨" style="-fx-font-size: 36px;"/>
                            <Label text="Emergency SOS"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                            <Label text="Instant emergency assistance at the touch of a button."
                                   wrapText="true"
                                   style="-fx-font-size: 12px; -fx-text-fill: #777; -fx-text-alignment: center;"/>
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>