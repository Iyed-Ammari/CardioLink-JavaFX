<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.Controllers.PredictionIAController"
            style="-fx-background-color: #F6F7FB;">

    <left>
        <VBox spacing="16" prefWidth="290"
              style="-fx-background-color: white; -fx-padding: 22 18 18 18; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, #F82239, #2F60F5); -fx-background-radius: 14;">
                    <Label text="CL" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="CardioLink" style="-fx-text-fill: #111827; -fx-font-size: 18px; -fx-font-weight: 800;"/>
                    <Label text="Admin · Marketplace" style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="🏠  Dashboard" onAction="#goToDashboard"
                        prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="📦  Produits" onAction="#goToProduits"
                        prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="📋  Commandes" onAction="#goToCommandes"
                        prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="🤖  Prédiction IA" onAction="#goToPredictionIA"
                        prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 14 0 0 0; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, rgba(248,34,57,0.22), rgba(47,96,245,0.22)); -fx-background-radius: 16;">
                    <Label text="AI" style="-fx-text-fill: #1F2937; -fx-font-weight: 900;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Prédiction" style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                    <Label text="FastAPI / IA" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-background-color: #F6F7FB; -fx-padding: 24;">

                    <!-- HERO -->
                    <HBox spacing="20"
                          style="-fx-background-color: #0D0F14; -fx-background-radius: 22; -fx-padding: 26 30;">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="CardioLink · Intelligence Artificielle"
                                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 11px; -fx-font-weight: 800;"/>
                            <Label text="Prédiction future des ventes"
                                   style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: 900;"/>
                            <Label text="Modèle IA basé sur les commandes PAYÉES"
                                   style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 13px; -fx-font-weight: 600;"/>
                            <Label fx:id="heroModelBadge"
                                   text="🌲 RandomForest · modèle ML"
                                   style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 4 10;"/>
                        </VBox>

                        <VBox alignment="CENTER_RIGHT" spacing="10">
                            <Label text="PÉRIODE"
                                   style="-fx-text-fill: rgba(255,255,255,0.30); -fx-font-size: 10px; -fx-font-weight: 800;"/>
                            <HBox alignment="CENTER_RIGHT" spacing="8">
                                <Label fx:id="heroPeriodLabel"
                                       text="📅 2026-01"
                                       style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: rgba(255,255,255,0.10); -fx-border-radius: 999; -fx-background-radius: 999; -fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 12px; -fx-font-weight: 700; -fx-padding: 6 14;"/>
                                <Label fx:id="futureTagLabel"
                                       text="FUTUR"
                                       style="-fx-background-color: rgba(47,96,245,0.30); -fx-text-fill: #93C5FD; -fx-font-size: 10px; -fx-font-weight: 900; -fx-padding: 4 8; -fx-background-radius: 8;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- SELECTOR -->
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: rgba(15,23,42,0.08); -fx-border-radius: 16; -fx-padding: 14 18;">
                        <Label text="🔮 Prédire un mois :"
                               style="-fx-text-fill: #64748B; -fx-font-size: 13px; -fx-font-weight: 700;"/>
                        <ComboBox fx:id="monthBox" prefWidth="200"
                                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: rgba(15,23,42,0.10); -fx-font-size: 13px; -fx-font-weight: 700;"/>
                        <Button text="📊 Lancer la prédiction" onAction="#handlePredict"
                                style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 12; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="infoPillLabel"
                               text="🤖 FastAPI · port 8001 · Modèle entraîné"
                               style="-fx-background-color: rgba(47,96,245,0.06); -fx-border-color: rgba(47,96,245,0.12); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #2F60F5; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 6 12;"/>
                    </HBox>

                    <!-- KPI -->
                    <HBox spacing="14">
                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: rgba(15,23,42,0.08); -fx-border-radius: 18; -fx-padding: 22;">
                            <Region prefHeight="3" maxHeight="3"
                                    style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-background-radius: 999;"/>
                            <Label text="📈 Pic max"
                                   style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                            <Label fx:id="maxLabel" text="0.00"
                                   style="-fx-text-fill: #0F172A; -fx-font-size: 34px; -fx-font-weight: 900;"/>
                            <Label text="Pic max prévu (commandes/jour)"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                        </VBox>

                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: rgba(15,23,42,0.08); -fx-border-radius: 18; -fx-padding: 22;">
                            <Region prefHeight="3" maxHeight="3"
                                    style="-fx-background-color: linear-gradient(to right, #10B981, #34D399); -fx-background-radius: 999;"/>
                            <Label text="📌 Nb jours pic"
                                   style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                            <Label fx:id="countLabel" text="0"
                                   style="-fx-text-fill: #2F60F5; -fx-font-size: 34px; -fx-font-weight: 900;"/>
                            <Label text="Jours de pic identifiés"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                        </VBox>

                        <VBox spacing="10" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: rgba(15,23,42,0.08); -fx-border-radius: 18; -fx-padding: 22;">
                            <Region prefHeight="3" maxHeight="3"
                                    style="-fx-background-color: linear-gradient(to right, #8B5CF6, #A78BFA); -fx-background-radius: 999;"/>
                            <Label text="📅 Mois"
                                   style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                            <Label fx:id="monthLabel" text="-"
                                   style="-fx-text-fill: #0F766E; -fx-font-size: 28px; -fx-font-weight: 900;"/>
                            <Label text="Période prédite"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                        </VBox>
                    </HBox>

                    <!-- RESULTS -->
                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: rgba(15,23,42,0.08); -fx-border-radius: 18; -fx-padding: 18;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🏆 Top jours prédits"
                                   style="-fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800;"/>
                            <Label fx:id="resultCountBadge"
                                   text="0 jour"
                                   style="-fx-background-color: #0D0F14; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: 700; -fx-padding: 4 12; -fx-background-radius: 999;"/>
                        </HBox>

                        <VBox fx:id="resultsContainer" spacing="12"/>

                        <Label fx:id="messageLabel" text=""
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-font-weight: 700;"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>