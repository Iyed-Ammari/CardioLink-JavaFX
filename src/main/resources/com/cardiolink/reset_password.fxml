<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cardiolink.controllers.ResetPasswordController"
      prefWidth="900" prefHeight="560"
      style="-fx-background-color: #f8f8fb;">

    <VBox prefWidth="450" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 50 40 50 40;">

        <Label text="❤ CardioLink"
               style="-fx-font-size: 16px; -fx-text-fill: #7F77DD;
                      -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>

        <Label text="Nouveau mot de passe"
               style="-fx-font-size: 26px; -fx-font-weight: bold;
                      -fx-text-fill: #1a1a2e;"/>

        <Label text="Entrez le code reçu par email puis votre nouveau mot de passe."
               wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #888888;
                      -fx-padding: 8 0 24 0;"/>

        <Label text="Code de réinitialisation"
               style="-fx-font-size: 13px; -fx-font-weight: bold;
                      -fx-text-fill: #1a1a2e;"/>
        <TextField fx:id="codeField"
                   promptText="Entrez le code reçu (8 caractères)"
                   prefHeight="42" prefWidth="370"
                   style="-fx-background-color: #f0f0fb;
                          -fx-border-color: #7F77DD; -fx-border-width: 1.5;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 10 14; -fx-font-size: 13px;"/>

        <Label text="Nouveau mot de passe"
               style="-fx-font-size: 13px; -fx-font-weight: bold;
                      -fx-text-fill: #1a1a2e; -fx-padding: 14 0 6 0;"/>
        <PasswordField fx:id="passwordField" promptText="••••••••"
                       prefHeight="42" prefWidth="370"
                       style="-fx-background-color: #f5f5fb;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

        <Label text="Confirmer le mot de passe"
               style="-fx-font-size: 13px; -fx-font-weight: bold;
                      -fx-text-fill: #1a1a2e; -fx-padding: 14 0 6 0;"/>
        <PasswordField fx:id="confirmField" promptText="••••••••"
                       prefHeight="42" prefWidth="370"
                       style="-fx-background-color: #f5f5fb;
                              -fx-border-color: #dedede; -fx-border-width: 1.5;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #E24B4A; -fx-font-size: 12px;
                      -fx-padding: 6 0 0 0;"/>
        <Label fx:id="successLabel" text=""
               style="-fx-text-fill: #27ae60; -fx-font-size: 12px;
                      -fx-padding: 6 0 0 0;"/>

        <Button text="Réinitialiser le mot de passe"
                onAction="#handleReset"
                prefWidth="370" prefHeight="44"
                style="-fx-background-color: linear-gradient(to right, #D4537E, #7F77DD);
                       -fx-text-fill: white; -fx-font-size: 15px;
                       -fx-font-weight: bold; -fx-background-radius: 10;
                       -fx-cursor: hand;">
            <VBox.margin><Insets top="20"/></VBox.margin>
        </Button>

        <Separator><VBox.margin><Insets top="16" bottom="10"/></VBox.margin></Separator>

        <HBox alignment="CENTER">
            <Label text="Retour à la connexion"
                   onMouseClicked="#goToLogin"
                   style="-fx-font-size: 13px; -fx-text-fill: #7F77DD;
                          -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: linear-gradient(
                       to bottom right, #fce4ec, #ede7f6);">
        <StackPane prefWidth="280" prefHeight="280"
                   style="-fx-background-color: rgba(180,160,220,0.25);
                          -fx-background-radius: 140;">
            <Label text="🔑" style="-fx-font-size: 64px;"/>
        </StackPane>
    </StackPane>
</HBox>