<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.Controllers.ProfilPatientController"
            prefWidth="1100" prefHeight="650"
            style="-fx-background-color: #f8f8ff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
              style="-fx-background-color: white; -fx-padding: 14 30;
                     -fx-border-color: #ececec; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="❤" style="-fx-text-fill: #E24B4A; -fx-font-size: 22px;"/>
                <Label text="CardioLink"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🏠 Home" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #333;"/>
            <Button text="👥 Community" onAction="#goCommunity"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #333;"/>
            <!-- Patient uniquement -->
            <Button fx:id="btnSuivis" text="📊 Mes Suivis" onAction="#goSuivis"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #333;"/>
            <Button fx:id="btnDossier" text="🗂 Mon Dossier Médical" onAction="#goDossier"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #333;"/>
            <!-- Commun -->
            <Button text="👤 Mon Profil" onAction="#goProfil"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #7F77DD; -fx-font-weight: bold;"/>
            <Button text="🚪 Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-font-size: 13px;
                           -fx-cursor: hand; -fx-text-fill: #888;"/>
            <StackPane>
                <Circle fx:id="avatarCircle" radius="18"
                        fill="linear-gradient(to bottom right, #E24B4A, #7F77DD)"/>
                <Label fx:id="avatarLabel" text="?"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </StackPane>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="24" style="-fx-padding: 40 0;">

                <Label text="👤  Mon Profil"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>

                <StackPane>
                    <Circle fx:id="bigAvatarCircle" radius="52"
                            fill="linear-gradient(to bottom right, #E24B4A, #7F77DD)"/>
                    <Label fx:id="bigAvatarLabel" text="?"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 36px;"/>
                </StackPane>

                <!-- Tableau infos -->
                <GridPane maxWidth="740"
                          style="-fx-background-color: white;
                                 -fx-border-color: #d0d0d0; -fx-border-width: 1;
                                 -fx-border-radius: 4; -fx-background-radius: 4;">
                    <columnConstraints>
                        <ColumnConstraints minWidth="200" maxWidth="200"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="50"/>
                        <RowConstraints minHeight="50"/>
                        <RowConstraints minHeight="50"/>
                        <RowConstraints minHeight="50"/>
                        <RowConstraints minHeight="50"/>
                    </rowConstraints>

                    <!-- Nom -->
                    <Label text="Nom"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #222;
                                  -fx-padding: 14 20; -fx-background-color: #fafafa;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 1 1 0;"/>
                    <Label fx:id="nomLabel" text="-"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 14px; -fx-text-fill: #444;
                                  -fx-padding: 14 20;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;"/>

                    <!-- Prénom -->
                    <Label text="Prénom"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #222;
                                  -fx-padding: 14 20; -fx-background-color: #fafafa;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 1 1 0;"/>
                    <Label fx:id="prenomLabel" text="-"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 14px; -fx-text-fill: #444;
                                  -fx-padding: 14 20;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;"/>

                    <!-- Email -->
                    <Label text="Email"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #222;
                                  -fx-padding: 14 20; -fx-background-color: #fafafa;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 1 1 0;"/>
                    <Label fx:id="emailLabel" text="-"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 14px; -fx-text-fill: #444;
                                  -fx-padding: 14 20;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;"/>

                    <!-- Téléphone -->
                    <Label text="Téléphone"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #222;
                                  -fx-padding: 14 20; -fx-background-color: #fafafa;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 1 1 0;"/>
                    <Label fx:id="telLabel" text="-"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 14px; -fx-text-fill: #444;
                                  -fx-padding: 14 20;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;"/>

                    <!-- Adresse — dernière ligne, pas de border-bottom -->
                    <Label text="Adresse"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #222;
                                  -fx-padding: 14 20; -fx-background-color: #fafafa;
                                  -fx-border-color: #d0d0d0; -fx-border-width: 0 1 0 0;"/>
                    <Label fx:id="adresseLabel" text="-"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                           maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 14px; -fx-text-fill: #444;
                                  -fx-padding: 14 20;"/>
                </GridPane>

                <!-- Boutons action -->
                <HBox spacing="16" alignment="CENTER">
                    <Button text="✏  Modifier mon profil" onAction="#goModifierProfil"
                            style="-fx-background-color: linear-gradient(to right, #E24B4A, #7F77DD);
                                   -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 13 32; -fx-background-radius: 25; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(226,75,74,0.35), 10, 0, 0, 4);"/>
                    <Button text="🗑  Supprimer mon compte" onAction="#handleDelete"
                            style="-fx-background-color: white; -fx-text-fill: #E24B4A;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 13 32; -fx-background-radius: 25; -fx-cursor: hand;
                                   -fx-border-color: #E24B4A; -fx-border-width: 1.5; -fx-border-radius: 25;"/>
                </HBox>

                <VBox minHeight="30"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>