<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cardiolink.Controllers.FaceLoginController"
      prefWidth="900" prefHeight="560"
      style="-fx-background-color: #f8f8fb;">

    <!-- GAUCHE -->
    <VBox prefWidth="450" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 40 40 40 40;" spacing="16">

        <Label text="👤  Connexion Faciale"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Positionnez votre visage face à la caméra."
               wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-text-alignment: center;"/>

        <!-- Prévisualisation webcam -->
        <StackPane style="-fx-background-color: #1a1a2e; -fx-background-radius: 12;"
                   prefWidth="320" prefHeight="240">
            <ImageView fx:id="webcamView"
                       fitWidth="320" fitHeight="240"
                       preserveRatio="true"/>
            <Label fx:id="cameraStatus" text="📷 Démarrage..."
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        </StackPane>

        <!-- Email pour identifier l'user -->
        <VBox spacing="6" maxWidth="370">
            <Label text="Votre Email"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <TextField fx:id="emailField" promptText="votre@email.com"
                       prefHeight="42" prefWidth="370"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #7F77DD; -fx-border-width: 1.5;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>
        </VBox>

        <Label fx:id="statusLabel" text=""
               wrapText="true" maxWidth="370"
               style="-fx-font-size: 13px; -fx-text-fill: #7F77DD; -fx-text-alignment: center;"/>
        <Label fx:id="errorLabel" text=""
               wrapText="true" maxWidth="370"
               style="-fx-font-size: 12px; -fx-text-fill: #E24B4A; -fx-text-alignment: center;"/>

        <!-- Bouton Vérifier -->
        <Button fx:id="btnVerify" text="📸  Vérifier mon visage"
                onAction="#handleFaceVerify"
                prefWidth="370" prefHeight="44"
                style="-fx-background-color: linear-gradient(to right, #D4537E, #7F77DD);
                       -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-cursor: hand;"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="← Retour au login normal"
                   onMouseClicked="#goToLogin"
                   style="-fx-font-size: 13px; -fx-text-fill: #7F77DD;
                          -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

    <!-- DROITE -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: linear-gradient(to bottom right, #fce4ec, #ede7f6);">
        <VBox alignment="CENTER" spacing="20">
            <StackPane prefWidth="200" prefHeight="200"
                       style="-fx-background-color: rgba(180,160,220,0.25);
                              -fx-background-radius: 100;">
                <Label text="👤" style="-fx-font-size: 64px;"/>
            </StackPane>
            <Label text="Reconnaissance Faciale"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7F77DD;"/>
            <Label text="Connectez-vous en utilisant&#10;votre visage en toute sécurité."
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: #888;
                          -fx-text-alignment: center;"/>
        </VBox>
    </StackPane>

</HBox>