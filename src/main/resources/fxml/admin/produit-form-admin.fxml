<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cardiolink.controllers.ProduitFormAdminController">

    <left>
        <VBox spacing="16" prefWidth="290"
              style="-fx-background-color: white; -fx-padding: 22 18 18 18; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, #F82239, #2F60F5); -fx-background-radius: 14;">
                    <Label text="CL" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 800;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="CardioLink" style="-fx-text-fill: #111827; -fx-font-size: 18px; -fx-font-weight: 800;"/>
                    <Label text="Admin · Marketplace" style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                <Button text="📦  Produits" onAction="#goToProduits" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>
                <Button text="📋  Commandes" onAction="#goToCommandes" prefHeight="42" maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"/>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 14 0 0 0; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: linear-gradient(to bottom right, rgba(248,34,57,0.22), rgba(47,96,245,0.22)); -fx-background-radius: 16;">
                    <Label text="AD" style="-fx-text-fill: #1F2937; -fx-font-weight: 900;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Admin" style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: 800;"/>
                    <Label text="ROLE_ADMIN" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-weight: 700;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="18" style="-fx-background-color: #F6F7FB; -fx-padding: 24;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label fx:id="pageTitleLabel" text="Ajouter un produit"
                           style="-fx-text-fill: #111827; -fx-font-size: 28px; -fx-font-weight: 800;"/>
                    <Label fx:id="pageSubtitleLabel" text="Créer un nouveau produit pour le catalogue CardioLink"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⬅ Retour" onAction="#goToProduits"
                        style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="18"
                  style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #E5E7EB; -fx-border-radius: 18; -fx-padding: 22;">

                <Label fx:id="formSectionTitleLabel" text="Informations du produit"
                       style="-fx-text-fill: #111827; -fx-font-size: 16px; -fx-font-weight: 800;"/>

                <GridPane hgap="16" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Nom *" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>
                    <Label text="Prix (DT) *" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>

                    <TextField fx:id="nomField" promptText="Ex: Stéthoscope CardioLink Pro"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 10 12;"/>
                    <TextField fx:id="prixField" promptText="Ex: 199.99"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"
                               style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 10 12;"/>

                    <Label text="Stock *" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>
                    <Label text="Catégorie *" GridPane.rowIndex="2" GridPane.columnIndex="1"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>

                    <TextField fx:id="stockField" promptText="Ex: 25"
                               GridPane.rowIndex="3" GridPane.columnIndex="0"
                               style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 10 12;"/>
                    <ComboBox fx:id="categorieBox" promptText="Choisir une catégorie"
                              maxWidth="1.7976931348623157E308"
                              GridPane.rowIndex="3" GridPane.columnIndex="1"
                              style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB;"/>

                    <Label text="Image URL" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>

                    <HBox spacing="10" GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.columnSpan="2">
                        <TextField fx:id="imageUrlField" promptText="https://... ou choisir un fichier image"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 10 12;"/>
                        <Button text="🖼 Choisir" onAction="#handleChooseImage"
                                style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 16; -fx-cursor: hand;"/>
                    </HBox>

                    <Label fx:id="imageHintLabel" text="Formats conseillés : PNG, JPG, JPEG, WEBP"
                           GridPane.rowIndex="6" GridPane.columnIndex="0" GridPane.columnSpan="2"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>

                    <Label text="Description" GridPane.rowIndex="7" GridPane.columnIndex="0"
                           style="-fx-font-weight: 700; -fx-text-fill: #111827;"/>

                    <TextArea fx:id="descriptionArea" promptText="Description du produit médical"
                              prefRowCount="4" wrapText="true"
                              GridPane.rowIndex="8" GridPane.columnIndex="0" GridPane.columnSpan="2"
                              style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #E5E7EB; -fx-padding: 10 12;"/>
                </GridPane>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       style="-fx-font-size: 13px; -fx-font-weight: 700;"/>

                <HBox spacing="12">
                    <Button fx:id="saveButton" text="Enregistrer" onAction="#handleSave"
                            style="-fx-background-color: linear-gradient(to right, #F82239, #2F60F5); -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 12; -fx-padding: 10 22; -fx-cursor: hand;"/>
                    <Button text="Annuler / Réinitialiser" onAction="#handleReset"
                            style="-fx-background-color: white; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 18; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
