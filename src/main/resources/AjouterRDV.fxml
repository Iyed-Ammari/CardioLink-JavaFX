<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="550.0" style="-fx-background-color: #1a1c2e;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cardiolink.Controllers.AjouterRDV">
    <children>
        <VBox alignment="TOP_LEFT" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label fx:id="titleLabel" text="Prendre un Rendez-vous" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label text="Veuillez renseigner les détails de la consultation" textFill="#826cfd">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="8.0">
                            <Label text="Médecin" textFill="#b0b0b0" />
                            <ComboBox fx:id="medecin" prefHeight="45.0" prefWidth="500.0" promptText="Sélectionner un médecin" style="-fx-background-color: #25273c; -fx-text-fill: white; -fx-background-radius: 10; -fx-border-color: #3d3f58; -fx-border-radius: 10;" />
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Date" textFill="#b0b0b0" />
                                    <DatePicker fx:id="date" prefHeight="45.0" prefWidth="250.0" style="-fx-control-inner-background: #25273c; -fx-background-color: #25273c;" />
                                </VBox>
                                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                    <Label text="Heure" textFill="#b0b0b0" />
                                    <ComboBox fx:id="heure" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #25273c; -fx-background-radius: 10; -fx-border-color: #3d3f58; -fx-border-radius: 10;" />
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="8.0">
                            <Label text="Type de consultation" textFill="#b0b0b0" />
                            <ComboBox fx:id="type" prefHeight="45.0" prefWidth="500.0" style="-fx-background-color: #25273c; -fx-background-radius: 10; -fx-border-color: #3d3f58; -fx-border-radius: 10;" />
                        </VBox>

                        <VBox spacing="8.0">
                            <Label text="Remarques additionnelles" textFill="#b0b0b0" />
                            <TextArea fx:id="remarques" prefHeight="100.0" prefWidth="500.0" promptText="Saisissez vos remarques ici..." style="-fx-control-inner-background: #25273c; -fx-text-fill: white; -fx-background-radius: 10; -fx-border-color: #3d3f58;" wrapText="true" />
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#save" prefHeight="50.0" prefWidth="500.0" style="-fx-background-color: linear-gradient(to right, #ff5f6d, #826cfd); -fx-background-radius: 12; -fx-cursor: hand;" text="Confirmer le rendez-vous" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: transparent;" text="Annuler" textFill="#e74c3c" underline="true">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#goToMenu"
                                style="-fx-background-color: #25273c; -fx-background-radius: 50; -fx-cursor: hand;"
                                text="🏠 Accueil" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>