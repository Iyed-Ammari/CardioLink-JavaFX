<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cardiolink.Controllers.ForgotPasswordController"
      prefWidth="900" prefHeight="560"
      style="-fx-background-color: #f8f8fb;">

    <!-- GAUCHE : Formulaire -->
    <VBox prefWidth="450" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 50 40 50 40;">

        <Label text="Mot de passe oublié ?"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
        <Label text="Entrez votre email pour recevoir un code de réinitialisation."
               wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-padding: 8 0 24 0;"/>

        <!-- ══ ÉTAPE 1 : Email ══ -->
        <VBox fx:id="step1Panel" spacing="10">
            <Label text="Email Address"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <TextField fx:id="emailField" promptText="votre@email.com"
                       prefHeight="42" prefWidth="370"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #7F77DD; -fx-border-width: 1.5;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 12px;"/>
            <Label fx:id="successLabel" text=""
                   style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>

            <Button fx:id="btnSendCode" text="📧  Envoyer le code"
                    onAction="#handleSendCode"
                    prefWidth="370" prefHeight="44"
                    style="-fx-background-color: linear-gradient(to right, #D4537E, #7F77DD);
                           -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Button>
        </VBox>

        <!-- ══ ÉTAPE 2 : Code + Nouveau mot de passe ══ -->
        <VBox fx:id="step2Panel" spacing="10" visible="false" managed="false">
            <Label text="Code de vérification"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
            <TextField fx:id="codeField" promptText="000000"
                       prefHeight="42" prefWidth="370"
                       style="-fx-background-color: #f0f0fb;
                              -fx-border-color: #7F77DD; -fx-border-width: 1.5;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 18px;
                              -fx-alignment: CENTER; -fx-font-weight: bold;"/>

            <Label text="Nouveau mot de passe"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 10 0 0 0;"/>
            <PasswordField fx:id="newPasswordField" promptText="••••••••"
                           prefHeight="42" prefWidth="370"
                           style="-fx-background-color: #f5f5fb;
                                  -fx-border-color: #dedede; -fx-border-width: 1.5;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <Label text="Confirmer le mot de passe"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                          -fx-text-fill: #1a1a2e; -fx-padding: 6 0 0 0;"/>
            <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                           prefHeight="42" prefWidth="370"
                           style="-fx-background-color: #f5f5fb;
                                  -fx-border-color: #dedede; -fx-border-width: 1.5;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px;"/>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #E24B4A; -fx-font-size: 12px;"/>
            <Label fx:id="successLabel" text=""
                   style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>

            <Button fx:id="btnResetPassword" text="🔑  Réinitialiser le mot de passe"
                    onAction="#handleResetPassword"
                    prefWidth="370" prefHeight="44"
                    style="-fx-background-color: linear-gradient(to right, #D4537E, #7F77DD);
                           -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Button>
        </VBox>

        <Separator><VBox.margin><Insets top="20" bottom="14"/></VBox.margin></Separator>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Retour à la connexion ?"
                   style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
            <Label text="Se connecter"
                   onMouseClicked="#goToLogin"
                   style="-fx-font-size: 13px; -fx-text-fill: #7F77DD;
                          -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

    <!-- DROITE : Visuel décoratif -->
    <StackPane HBox.hgrow="ALWAYS"
               style="-fx-background-color: linear-gradient(to bottom right, #fce4ec, #ede7f6);">
        <VBox alignment="CENTER" spacing="20">
            <StackPane prefWidth="200" prefHeight="200"
                       style="-fx-background-color: rgba(180,160,220,0.25);
                              -fx-background-radius: 100;">
                <Label text="🔑" style="-fx-font-size: 64px;"/>
            </StackPane>
            <Label text="Réinitialisation sécurisée"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7F77DD;"/>
            <Label text="Un code à 6 chiffres sera envoyé&#10;à votre adresse email."
                   wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #888;
                                          -fx-text-alignment: center;"/>
        </VBox>
    </StackPane>

</HBox>